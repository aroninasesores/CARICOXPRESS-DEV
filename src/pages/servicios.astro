---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Banner from "../components/Banner.astro";
import CTA from "../components/CTA.astro";
import {brand} from "../config/brand";
import {Image} from "astro:assets";

import imagenServicios from "../assets/images/services/servicios.png";

const services = [
  {
    title: "Envíos Aéreos Express",
    description:
      "Ideal para compras urgentes o paquetes de alta prioridad. Movilizamos tu carga desde Miami hacia Venezuela con procesos ágiles, seguimiento oportuno y entrega puerta a puerta.",
  },
  {
    title: "Envíos Marítimos Consolidados",
    description:
      "Una solución eficiente para cajas pesadas, mercancía comercial o envíos de mayor volumen. Consolidamos tu carga para optimizar costos y coordinar el proceso hasta la entrega final.",
  },
  {
    title: "Casillero Internacional en Miami",
    description:
      "Recibe una dirección física en Miami para enviar tus compras de Amazon, eBay u otros proveedores. Cada cliente cuenta con un identificador propio para facilitar la recepción y organización de sus paquetes.",
  },
  {
    title: "Prealerta de Paquetes",
    description:
      "Notifica tus compras antes de que lleguen al almacén para agilizar su identificación, registro y preparación. La prealerta permite un proceso más ordenado y reduce retrasos innecesarios.",
  },
  {
    title: "Recepción, Consolidación y Preparación",
    description:
      "Recibimos tus paquetes, verificamos su estado exterior y agrupamos varias compras en un solo despacho cuando sea conveniente. También podemos acondicionar la carga para aprovechar mejor el espacio y facilitar su traslado.",
  },
];

const icons = [
  // Avión / Envíos Aéreos
  '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 10h4a2 2 0 0 1 0 4h-4l-4 7h-3l2 -7h-4l-2 2h-3l2 -4l-2 -4h3l2 2h4l-2 -7h3l4 7" />',

  // Barco / Envíos Marítimos
  '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M22 14l-2 5H4l-2-5h20zm-2 0V9a1 1 0 00-1-1h-3V5a1 1 0 00-1-1H9a1 1 0 00-1 1v3H5a1 1 0 00-1 1v5m4-6v6m4-6v6m4-6v6" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 18h22M3 21h18" />',

  // Ubicación / Casillero
  '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />',

  // Notificación / Prealerta
  '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />',

  // Caja / Consolidación y preparación
  '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />',
];
---

<BaseLayout
  title="Servicios"
  description={`Explore la amplia gama de servicios ofrecidos por ${brand.name}. Desde envíos aéreos express hasta soluciones de carga marítima, asignación de casilleros internacionales y servicios personalizados de prealerta y consolidación. Descubra cómo podemos ayudarlo a optimizar su logística y garantizar el éxito de cada envío.`}
>
  <Header slot="header" />

  <Banner title="Nuestros Servicios" />

  <section>
    <div
      class="py-section mx-auto max-w-site flex flex-col items-center px-4 sm:px-6"
    >
      <div
        class="flex flex-col items-center mx-auto mb-10 max-w-2xl gap-y-4 text-center lg:mb-14"
      >
        <h2 class="font-heading text-h2 font-bold uppercase text-text">
          Qué podemos hacer por usted
        </h2>
        <p class="mt-3 text-text-muted leading-relaxed">
          Ninguna carga es demasiado grande o pequeña para nuestro equipo de
          transporte. Ya sea que necesite importar un teléfono o o realizar una
          mudanza completa, estamos aquí para ayudarlo en cada paso del proceso.
        </p>
        <a
          href="#nuestros-servicios"
          class="inline-flex max-w-sm min-h-11 gap-x-1.5 items-center justify-center rounded-md bg-accent px-6 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >
          Conozca nuestros servicios
        </a>
      </div>

      <div
        class="max-w-2xl order-1 overflow-hidden rounded-lg aspect-4/3 lg:order-2 shadow-xl shadow-blue-900/30"
        transition:name="hero-image"
      >
        <Image
          src={imagenServicios}
          alt="Buque cargero con contenedores en el mar, simbolizando los servicios de transporte marítimo y logística internacional de Caricoxpress."
          width={800}
          height={600}
          loading="eager"
          decoding="async"
          class="size-full object-cover"
        />
      </div>
    </div>
    <section></section>

    <section
      class="bg-surface py-section"
      id="nuestros-servicios"
    >
      <div class="container grid grid-cols-1 gap-8 md:grid-cols-2">
        {
          services.map((service, i) => (
            <div class="flex gap-5 rounded-lg border border-border bg-background p-6 shadow-sm">
              <div class="flex size-12 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
                <svg
                  class="size-6"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                  set:html={icons[i % icons.length]}
                />
              </div>
              <div>
                <h3 class="font-heading text-h3 font-semibold text-text">
                  {service.title}
                </h3>
                <p class="mt-2 text-text-muted leading-relaxed">
                  {service.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </section>

  <CTA />

  <Footer slot="footer" />
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Banner from "../../components/Banner.astro";
import Form from "../../components/Form.astro";
import {localBusinessSchema, seo} from "../../config/seo";
import {client} from "../../data/client";
---

<BaseLayout
  title={seo.contact.title}
  description={seo.contact.description}
  schema={localBusinessSchema}
>
  <Header slot="header" />

  <Banner title="Contáctenos" />

  <section>
    <div
      class="mx-auto grid max-w-site grid-cols-1 gap-10 px-4 sm:px-6 lg:grid-cols-5 lg:gap-14"
    >
      <div class="lg:col-span-3">
        <Form
          title="Envíenos un mensaje"
          description="Complete el formulario a continuación y nos pondremos en contacto con usted."
          action="/contacto/mensaje-enviado"
          containerClass="px-0"
        />
      </div>

      <aside class="space-y-8 py-section lg:col-span-2">
        <h2 class="font-heading text-h3 font-bold uppercase text-text">
          Información de contacto
        </h2>

        <div class="w-full lg:w-2/3">
          <a
            href={client.whatsapp.href}
            target="_blank"
            rel="noopener noreferrer"
            class="flex flex-row items-center justify-center gap-2 bg-green-500 rounded-md p-4 text-white font-medium transition-all hover:bg-green-600 shadow-lg shadow-green-300/50 hover:shadow-green-100/70"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="shrink-0"
              aria-hidden="true"
            >
              <path
                stroke="none"
                d="M0 0h24v24H0z"
                fill="none"
              />
              <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9" />
              <path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1" />
            </svg>
            <span>Escríbanos por WhatsApp</span>
          </a>
        </div>

        <div class="flex flex-col">
          <h3 class="font-heading text-lg font-semibold text-text">
            Llámenos
          </h3>
          <a
            href={`tel:${client.phoneForTel}`}
            class="mt-1 block text-primary-light font-medium transition-colors hover:text-primary"
          >
            {client.phoneFormatted}
          </a>
        </div>

        <div class="flex flex-col">
          <h3 class="font-heading text-lg font-semibold text-text">
            Escríbanos un correo electrónico
          </h3>
          <a
            href={`mailto:${client.email}`}
            class="mt-1 block text-primary-light font-medium transition-colors hover:text-primary"
          >
            {client.email}
          </a>
        </div>

        <div class="flex flex-col">
          <h3 class="font-heading text-lg font-semibold text-text">
            Ubicación
          </h3>
          <a
            href={client.address.mapLink}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-1 block text-text-muted transition-colors hover:text-text"
          >
            {client.address.lineOne}
            {
              client.address.lineTwo && (
                <>
                  {" "}
                  {client.address.lineTwo}
                  <br />
                </>
              )
            }
            {client.address.city}, {client.address.state} {client.address.zip}
          </a>
        </div>

        <div class="flex flex-col">
          <h3 class="font-heading text-lg font-semibold text-text">
            Horarios
          </h3>
          <p class="mt-1 text-text-muted">
            {
              client.hours.map((line) => (
                <>
                  {line}
                  <br />
                </>
              ))
            }
          </p>
        </div>
      </aside>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

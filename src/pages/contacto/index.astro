---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Banner from "../../components/Banner.astro";
import {brand} from "../../config/brand";
import {client} from "../../data/client";
---

<BaseLayout
  title="Contacto"
  description={`Pónganse en contacto con ${brand.name}. Solicite una cotización gratuita o háganos una pregunta.`}
>
  <Header slot="header" />

  <Banner title="Contáctenos" />

  <section class="py-section">
    <div
      class="mx-auto grid max-w-site grid-cols-1 gap-10 px-4 sm:px-6 lg:grid-cols-5 lg:gap-14"
    >
      <!-- Form -->
      <div class="lg:col-span-3">
        <h2 class="font-heading text-h2 font-bold uppercase text-text">
          Envíenos un mensaje
        </h2>
        <p class="mt-2 mb-8 text-text-muted text-pretty">
          Complete el formulario a continuación y nos pondremos en contacto con
          usted.
        </p>

        <form
          name="contact"
          method="POST"
          data-netlify="true"
          netlify-honeypot="bot-field"
          action="/contacto/mensaje-enviado"
          class="flex flex-col gap-5"
        >
          <input
            type="hidden"
            name="form-name"
            value="contact"
          />
          <p
            class="hidden"
            aria-hidden="true"
          >
            <label>
              Deje este campo vacío: <input
                name="bot-field"
                tabindex="-1"
                autocomplete="off"
              />
            </label>
          </p>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">
              Nombre <span
                class="text-accent"
                aria-hidden="true"
              >
                *
              </span>
            </span>
            <input
              type="text"
              name="name"
              required
              autocomplete="name"
              class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">
              Email <span
                class="text-accent"
                aria-hidden="true"
              >
                *
              </span>
            </span>
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">Teléfono</span>
            <input
              type="tel"
              name="phone"
              autocomplete="tel"
              inputmode="tel"
              class="min-h-[44px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
            />
          </label>

          <label class="flex flex-col gap-1.5">
            <span class="text-sm font-medium text-text">
              Mensaje <span
                class="text-accent"
                aria-hidden="true"
              >
                *
              </span>
            </span>
            <textarea
              name="message"
              rows="5"
              required
              class="min-h-[120px] rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 resize-y"
            >
            </textarea>
          </label>
          <button
            type="submit"
            class="mt-2 inline-flex min-h-[44px] cursor-pointer items-center justify-center self-start rounded-md bg-accent px-8 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
          >
            Enviar Mensaje
          </button>
        </form>
      </div>

      <!-- Contact info sidebar -->
      <aside class="space-y-8 lg:col-span-2 mt-10 lg:mt-12">
        <h2 class="font-heading text-h3 font-bold uppercase text-text">
          Información de contacto
        </h2>
        <div class="w-full lg:w-2/3">
          <a
            href="https://wa.me/584141018217?text=Hola,%20quisiera%20solicitar%20un%20presupuesto%20para%20un%20env%C3%ADo 📦.%20%C2%BFMe%20podr%C3%ADan%20dar%20m%C3%A1s%20informaci%C3%B3n?"
            class="flex flex-row items-center justify-center gap-2 bg-green-500 rounded-md p-4 text-white font-medium transition-all hover:bg-green-600 shadow-lg shadow-green-300/50 hover:shadow-green-100/70"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="icon icon-tabler icons-tabler-outline icon-tabler-brand-whatsapp shrink-0"
            >
              <path
                stroke="none"
                d="M0 0h24v24H0z"
                fill="none"
              >
              </path>
              <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"></path>
              <path
                d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"
              >
              </path>
            </svg>
            <span>Escríbanos por WhatsApp</span>
          </a>
        </div>

        <div class="flex flex-col">
          <div class="flex flex-row items-center gap-2">
            <svg
              class="size-5 text-primary"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2.5"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              >
              </path>
            </svg>
            <h3 class="font-heading text-lg font-semibold text-text">
              Llámenos
            </h3>
          </div>
          <a
            href={`tel:${client.phoneForTel}`}
            class="mt-1 block text-primary-light font-medium transition-colors hover:text-primary"
          >
            {client.phoneFormatted}
          </a>
        </div>

        <div class="flex flex-col">
          <div class="flex flex-row items-center gap-2">
            <svg
              class="size-5 text-primary"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2.5"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              >
              </path>
            </svg>
            <h3 class="font-heading text-lg font-semibold text-text">
              Escríbanos un correo electrónico
            </h3>
          </div>
          <a
            href={`mailto:${client.email}`}
            class="mt-1 block text-primary-light font-medium transition-colors hover:text-primary"
          >
            {client.email}
          </a>
        </div>

        <div class="flex flex-col">
          <div class="flex flex-row items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="icon icon-tabler icons-tabler-outline icon-tabler-map-pin"
            >
              <path
                stroke="none"
                d="M0 0h24v24H0z"
                fill="none"
              >
              </path><path d="M9 11a3 3 0 1 0 6 0a3 3 0 0 0 -6 0"></path><path
                d="M17.657 16.657l-4.243 4.243a2 2 0 0 1 -2.827 0l-4.244 -4.243a8 8 0 1 1 11.314 0"
              >
              </path>
            </svg>
            <h3 class="font-heading text-lg font-semibold text-text">
              Ubicación
            </h3>
          </div>
          <a
            href={client.address.mapLink}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-1 block text-text-muted transition-colors hover:text-text"
          >
            {client.address.lineOne}
            {
              client.address.lineTwo && (
                <>
                  {client.address.lineTwo}
                  <br />
                </>
              )
            }
            {client.address.city}, {client.address.state}
            {client.address.zip}
          </a>
        </div>

        <div class="flex flex-col">
          <div class="flex flex-row items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="icon icon-tabler icons-tabler-outline icon-tabler-clock-hour-3"
            >
              <path
                stroke="none"
                d="M0 0h24v24H0z"
                fill="none"
              >
              </path><path d="M3 12a9 9 0 1 0 18 0a9 9 0 1 0 -18 0"></path><path
                d="M12 12h3.5"
              >
              </path><path d="M12 7v5"></path>
            </svg>
            <h3 class="font-heading text-lg font-semibold text-text">
              Horarios
            </h3>
          </div>
          <p class="mt-1 text-text-muted">
            Lunes – Viernes: 8:00 AM – 6:00 PM<br />
            Sábado: 9:00 AM – 2:00 PM<br />
            Domingo: Cerrado<br />
          </p>
        </div>
      </aside>
    </div>
  </section>
  <Footer slot="footer" />
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Banner from "../components/Banner.astro";

const shippingFields = [
  ["recipient_name", "Nombre / Recipient"],
  ["locker_code", "Código de casillero"],
  ["address_line_1", "Dirección / Address"],
  ["address_line_2", "Address Line 2"],
  ["city", "Ciudad / City"],
  ["state", "Estado / State"],
  ["postal_code", "ZIP Code"],
  ["country", "País / Country"],
  ["phone", "Teléfono / Phone"],
];

const fieldClass =
  "min-h-11 rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20";
---

<BaseLayout
  title="Mi casillero CaricoXpress"
  description="Consulta los datos públicos de tu casillero CaricoXpress con tu correo y contraseña."
>
  <Fragment slot="head">
    <meta
      name="robots"
      content="noindex, nofollow"
    />
  </Fragment>

  <Header slot="header" />

  <Banner title="Mi casillero" />

  <section class="bg-background py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div
        id="access-panel"
        class="mx-auto max-w-3xl rounded-lg border border-border bg-background p-6 shadow-sm sm:p-8"
      >
        <div class="text-center">
          <p class="text-sm font-bold uppercase text-accent">
            Mi CaricoXpress
          </p>
          <h1 class="mt-3 font-heading text-h2 font-bold uppercase text-text">
            Consulta tu casillero
          </h1>
          <p class="mx-auto mt-4 max-w-2xl leading-relaxed text-text-muted">
            Ingresa el correo y la contraseña que utilizaste al crear tu
            casillero.
          </p>
        </div>

        <div
          id="registration-success-message"
          class="mt-6 hidden rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700"
          role="status"
          aria-live="polite"
        >
          Tu casillero fue creado correctamente. Ingresa con tu correo y
          contraseña para consultar tus datos de envío.
        </div>

        <div
          id="access-error"
          class="mt-6 hidden rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"
          role="alert"
          aria-live="assertive"
          tabindex="-1"
        >
        </div>

        <form
          id="locker-access-form"
          class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2"
          novalidate
        >
          <label
            for="access-email"
            class="flex flex-col gap-1.5"
          >
            <span class="text-sm font-medium text-text">
              Correo electrónico <span
                class="text-accent"
                aria-hidden="true"
              >
                *
              </span>
            </span>
            <input
              id="access-email"
              name="email"
              type="email"
              autocomplete="email"
              required
              class={fieldClass}
              aria-describedby="access-email-error"
            />
            <span
              id="access-email-error"
              class="hidden text-sm text-red-600"
            >
              Indica un correo electrónico válido.
            </span>
          </label>

          <label
            for="access-password"
            class="flex flex-col gap-1.5"
          >
            <span class="text-sm font-medium text-text">
              Contraseña <span
                class="text-accent"
                aria-hidden="true"
              >
                *
              </span>
            </span>
            <input
              id="access-password"
              name="password"
              type="password"
              autocomplete="current-password"
              required
              class={fieldClass}
              aria-describedby="access-password-error"
            />
            <span
              id="access-password-error"
              class="hidden text-sm text-red-600"
            >
              Indica tu contraseña.
            </span>
          </label>

          <div class="flex flex-col gap-3 pt-2 sm:col-span-2 sm:flex-row sm:items-center">
            <button
              id="access-submit"
              type="submit"
              class="inline-flex min-h-11 cursor-pointer items-center justify-center rounded-md bg-accent px-8 py-3 text-base font-bold uppercase text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent disabled:cursor-not-allowed disabled:opacity-70"
            >
              <span data-label-idle>Ver mi casillero</span>
              <span
                data-label-loading
                class="hidden"
              >
                Consultando...
              </span>
            </button>
            <p
              id="access-status"
              class="text-sm text-text-muted"
              aria-live="polite"
            >
            </p>
          </div>
        </form>
      </div>

      <div
        id="locker-content"
        class="hidden"
      >
        <div class="mx-auto max-w-3xl text-center">
          <p class="text-sm font-bold uppercase text-accent">
            Casillero activo
          </p>
          <h1 class="mt-3 font-heading text-h2 font-bold uppercase text-text">
            Tu casillero CaricoXpress está listo
          </h1>
          <p class="mx-auto mt-4 max-w-2xl leading-relaxed text-text-muted">
            Ya puedes utilizar estos datos al realizar tus compras y envíos
            hacia nuestra dirección en Miami.
          </p>
        </div>

        <div class="mt-10 grid grid-cols-1 gap-8 lg:grid-cols-5">
          <div class="lg:col-span-2">
            <div class="overflow-hidden rounded-lg border border-border bg-primary text-primary-fg shadow-sm">
              <div class="border-b border-primary-fg/20 p-6">
                <p class="font-heading text-xl font-bold uppercase">
                  Carico Xpress
                </p>
              </div>
              <div class="p-6">
                <p
                  id="card-customer-name"
                  class="text-sm font-bold uppercase tracking-wider text-primary-fg/70"
                >
                </p>
                <p class="mt-8 text-sm font-bold uppercase text-primary-fg/70">
                  Tu casillero
                </p>
                <p
                  id="card-locker-code"
                  class="mt-2 font-heading text-4xl font-bold uppercase tracking-wide text-primary-fg sm:text-5xl"
                >
                </p>
                <button
                  id="copy-code"
                  type="button"
                  class="mt-6 inline-flex min-h-11 cursor-pointer items-center justify-center rounded-md bg-accent px-6 py-3 text-sm font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
                >
                  Copiar código
                </button>
                <p
                  id="copy-code-status"
                  class="mt-3 min-h-5 text-sm text-primary-fg/80"
                  aria-live="polite"
                >
                </p>
              </div>
            </div>

            <div class="mt-6 rounded-lg border border-border bg-surface p-5">
              <h2 class="font-heading text-lg font-semibold text-text">
                Cómo usar tus identificadores
              </h2>
              <p
                id="warehouse-id-note"
                class="mt-3 text-sm leading-relaxed text-text-muted"
              >
              </p>
              <p
                id="locker-code-note"
                class="mt-2 text-sm leading-relaxed text-text-muted"
              >
              </p>
            </div>
          </div>

          <div class="lg:col-span-3">
            <div class="rounded-lg border border-border bg-background p-6 shadow-sm sm:p-8">
              <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                <div>
                  <h2 class="font-heading text-h3 font-semibold text-text">
                    Datos para comprar y enviar
                  </h2>
                  <p class="mt-2 text-sm leading-relaxed text-text-muted">
                    Utiliza estos datos cuando realices compras en tiendas de
                    Estados Unidos. Tu código de casillero permite identificar
                    correctamente tus paquetes al llegar a CaricoXpress.
                  </p>
                </div>
                <button
                  id="copy-shipping"
                  type="button"
                  class="inline-flex min-h-11 shrink-0 cursor-pointer items-center justify-center rounded-md bg-accent px-6 py-3 text-sm font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
                >
                  Copiar datos de envío
                </button>
                <button
                  id="close-locker"
                  type="button"
                  class="inline-flex min-h-11 shrink-0 cursor-pointer items-center justify-center rounded-md border-2 border-primary px-6 py-3 text-sm font-bold text-primary transition-colors hover:bg-primary/5 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
                >
                  Cerrar casillero
                </button>
              </div>
              <p
                id="copy-shipping-status"
                class="mt-3 min-h-5 text-sm text-text-muted"
                aria-live="polite"
              >
              </p>

              <dl class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
                {
                  shippingFields.map(([key, label]) => (
                    <div
                      class="rounded-md border border-border bg-surface p-4"
                      data-shipping-row={key}
                    >
                      <dt class="text-xs font-bold uppercase tracking-wider text-text-muted">
                        {label}
                      </dt>
                      <dd
                        id={`shipping-${key}`}
                        class="mt-1 break-words text-base font-semibold text-text"
                      >
                      </dd>
                    </div>
                  ))
                }
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script>
  (() => {
    const publicApiUrl = import.meta.env.PUBLIC_API_URL;
    const accessEndpoint = publicApiUrl
      ? `${publicApiUrl.replace(/\/$/, "")}/api/public/locker-access`
      : "";
    const invalidCredentialsMessage =
      "El correo o la contraseña no son correctos.";
    const rateLimitMessage =
      "Has realizado varios intentos en poco tiempo. Espera un momento antes de intentar nuevamente.";
    const genericErrorMessage =
      "No pudimos consultar tu casillero en este momento. Intenta nuevamente más tarde.";

    const accessPanel = document.getElementById("access-panel");
    const form = document.getElementById("locker-access-form");
    const submitButton = document.getElementById("access-submit");
    const status = document.getElementById("access-status");
    const accessError = document.getElementById("access-error");
    const successMessage = document.getElementById("registration-success-message");
    const idleLabel = form?.querySelector("[data-label-idle]");
    const loadingLabel = form?.querySelector("[data-label-loading]");
    const content = document.getElementById("locker-content");
    const cardCustomerName = document.getElementById("card-customer-name");
    const cardLockerCode = document.getElementById("card-locker-code");
    const warehouseIdNote = document.getElementById("warehouse-id-note");
    const lockerCodeNote = document.getElementById("locker-code-note");
    const copyCodeButton = document.getElementById("copy-code");
    const copyCodeStatus = document.getElementById("copy-code-status");
    const copyShippingButton = document.getElementById("copy-shipping");
    const copyShippingStatus = document.getElementById("copy-shipping-status");
    const closeLockerButton = document.getElementById("close-locker");

    if (!(form instanceof HTMLFormElement)) return;
    if (!(submitButton instanceof HTMLButtonElement)) return;

    let lockerCode = "";
    let shippingData = null;

    if (new URLSearchParams(window.location.search).get("registro") === "exitoso") {
      successMessage?.classList.remove("hidden");
    }

    const setLoading = (isLoading) => {
      submitButton.disabled = isLoading;
      idleLabel?.classList.toggle("hidden", isLoading);
      loadingLabel?.classList.toggle("hidden", !isLoading);
      if (status) {
        status.textContent = isLoading ? "Consultando..." : "";
      }
    };

    const setError = (message) => {
      if (accessError) {
        accessError.textContent = message;
        accessError.classList.remove("hidden");
      }
    };

    const clearErrors = () => {
      accessError?.classList.add("hidden");
      form.querySelectorAll('[id$="-error"]').forEach((error) => {
        error.classList.add("hidden");
      });
      form.querySelectorAll("[aria-invalid]").forEach((field) => {
        field.removeAttribute("aria-invalid");
      });
    };

    const showNativeFieldErrors = () => {
      const fields = form.querySelectorAll("input");
      fields.forEach((field) => {
        if (!(field instanceof HTMLInputElement)) return;
        if (field.validity.valid) return;
        field.setAttribute("aria-invalid", "true");
        document.getElementById(`${field.id}-error`)?.classList.remove("hidden");
      });
    };

    const readJsonResponse = async (response) => {
      try {
        return await response.json();
      } catch {
        return null;
      }
    };

    const isRecord = (value) => value !== null && typeof value === "object";
    const hasString = (value) => typeof value === "string" && value.trim().length > 0;

    const isValidLockerResponse = (data) => {
      if (!isRecord(data) || !isRecord(data.shipping_data)) return false;
      if (!hasString(data.customer_name) || !hasString(data.locker_code)) return false;
      if (!hasString(data.shipping_data.recipient_name)) return false;
      if (!hasString(data.shipping_data.locker_code)) return false;

      return data.locker_code === data.shipping_data.locker_code;
    };

    const setText = (id, value) => {
      const element = document.getElementById(id);
      if (element) {
        element.textContent = typeof value === "string" ? value : "";
      }
    };

    const setOptionalRow = (key, value) => {
      const row = document.querySelector(`[data-shipping-row="${key}"]`);
      row?.classList.toggle("hidden", !hasString(value));
    };

    const renderLocker = (data) => {
      lockerCode = data.locker_code;
      shippingData = data.shipping_data;

      if (cardCustomerName) {
        cardCustomerName.textContent = data.customer_name;
      }
      if (cardLockerCode) {
        cardLockerCode.textContent = data.locker_code;
      }
      if (warehouseIdNote) {
        warehouseIdNote.textContent = hasString(shippingData.address_line_2)
          ? `${shippingData.address_line_2} identifica a CaricoXpress dentro del almacén en Miami.`
          : "El identificador del almacén debe colocarse cuando esté disponible en tus datos de envío.";
      }
      if (lockerCodeNote) {
        lockerCodeNote.textContent = `Tu código ${data.locker_code} identifica tus compras y paquetes dentro de CaricoXpress.`;
      }

      [
        "recipient_name",
        "locker_code",
        "address_line_1",
        "address_line_2",
        "city",
        "state",
        "postal_code",
        "country",
        "phone",
      ].forEach((key) => {
        setText(`shipping-${key}`, shippingData[key]);
      });

      setOptionalRow("address_line_2", shippingData.address_line_2);
      setOptionalRow("phone", shippingData.phone);
      accessPanel?.classList.add("hidden");
      content?.classList.remove("hidden");
    };

    const getShippingCopyText = () => {
      if (!shippingData) return "";

      const lines = [
        `${shippingData.recipient_name} - ${shippingData.locker_code}`,
        shippingData.address_line_1,
        shippingData.address_line_2,
        `${shippingData.city}, ${shippingData.state} ${shippingData.postal_code}`.trim(),
        shippingData.country,
        shippingData.phone,
      ];

      return lines.filter((line) => hasString(line)).join("\n");
    };

    const setCopyStatus = (element, message) => {
      if (!element) return;
      element.textContent = message;
      window.setTimeout(() => {
        element.textContent = "";
      }, 3000);
    };

    const copyText = async (text, successMessageText, statusElement) => {
      if (!navigator.clipboard || !hasString(text)) {
        setCopyStatus(statusElement, "No pudimos copiar en este momento.");
        return;
      }

      try {
        await navigator.clipboard.writeText(text);
        setCopyStatus(statusElement, successMessageText);
      } catch {
        setCopyStatus(statusElement, "No pudimos copiar en este momento.");
      }
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (submitButton.disabled) return;

      clearErrors();

      if (!form.checkValidity()) {
        showNativeFieldErrors();
        return;
      }

      if (!accessEndpoint) {
        setError(genericErrorMessage);
        return;
      }

      const emailField = form.elements.namedItem("email");
      const passwordField = form.elements.namedItem("password");
      if (!(emailField instanceof HTMLInputElement)) return;
      if (!(passwordField instanceof HTMLInputElement)) return;

      setLoading(true);

      try {
        const response = await fetch(accessEndpoint, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify({
            email: emailField.value,
            password: passwordField.value,
          }),
        });

        if (response.status === 401) {
          setError(invalidCredentialsMessage);
          setLoading(false);
          return;
        }

        if (response.status === 429) {
          setError(rateLimitMessage);
          setLoading(false);
          return;
        }

        if (!response.ok) {
          setError(genericErrorMessage);
          setLoading(false);
          return;
        }

        const data = await readJsonResponse(response);
        if (!isValidLockerResponse(data)) {
          setError(genericErrorMessage);
          setLoading(false);
          return;
        }

        renderLocker(data);
      } catch {
        setError(genericErrorMessage);
        setLoading(false);
      }
    });

    copyCodeButton?.addEventListener("click", () => {
      copyText(lockerCode, "Código copiado", copyCodeStatus);
    });

    copyShippingButton?.addEventListener("click", () => {
      copyText(getShippingCopyText(), "Datos de envío copiados", copyShippingStatus);
    });
    closeLockerButton?.addEventListener("click", () => {
      window.location.replace("/mi-casillero");
    });
  })();
</script>

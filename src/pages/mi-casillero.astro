---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Banner from "../components/Banner.astro";
import Logo from "../components/logo.astro";

const fieldClass =
  "min-h-11 rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20";
---

<BaseLayout
  title="Mi casillero CaricoXpress"
  description="Consulta los datos públicos de tu casillero CaricoXpress con tu correo y contraseña."
>
  <Fragment slot="head">
    <meta
      name="robots"
      content="noindex, nofollow"
    />
  </Fragment>

  <Header slot="header" />

  <Banner title="Mi casillero" />

  <section class="bg-background py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div
        id="access-panel"
        class="mx-auto max-w-3xl rounded-lg border border-border bg-background p-6 shadow-sm sm:p-8"
      >
        <div class="text-center">
          <p class="text-sm font-bold uppercase text-accent">Mi CaricoXpress</p>
          <h1 class="mt-3 font-heading text-h2 font-bold uppercase text-text">
            Consulta tu casillero
          </h1>
          <p class="mx-auto mt-4 max-w-2xl leading-relaxed text-text-muted">
            Ingresa el correo y la contraseña que utilizaste al crear tu
            casillero.
          </p>
        </div>

        <div
          id="registration-success-message"
          class="mt-6 hidden rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700"
          role="status"
          aria-live="polite"
        >
          Tu casillero fue creado correctamente. Ingresa con tu correo y
          contraseña para consultar tus datos de envío.
        </div>

        <div
          id="access-error"
          class="mt-6 hidden rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700"
          role="alert"
          aria-live="assertive"
          tabindex="-1"
        >
        </div>

        <form
          id="locker-access-form"
          class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2"
          novalidate
        >
          <label
            for="access-email"
            class="flex flex-col gap-1.5"
          >
            <span class="text-sm font-medium text-text">
              Correo electrónico <span
                class="text-accent"
                aria-hidden="true"
              >
                *
              </span>
            </span>
            <input
              id="access-email"
              name="email"
              type="email"
              autocomplete="email"
              required
              class={fieldClass}
              aria-describedby="access-email-error"
            />
            <span
              id="access-email-error"
              class="hidden text-sm text-red-600"
            >
              Indica un correo electrónico válido.
            </span>
          </label>

          <label
            for="access-password"
            class="flex flex-col gap-1.5"
          >
            <span class="text-sm font-medium text-text">
              Contraseña <span
                class="text-accent"
                aria-hidden="true"
              >
                *
              </span>
            </span>
            <div class="relative">
              <input
                id="access-password"
                name="password"
                type="password"
                autocomplete="current-password"
                required
                class={`${fieldClass} w-full !pr-12`}
                aria-describedby="access-password-error"
              />
              <button
                type="button"
                class="absolute inset-y-0 right-0 inline-flex min-h-11 w-11 cursor-pointer items-center justify-center rounded-r-md text-text-muted transition-colors hover:text-primary focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
                data-password-toggle="access-password"
                aria-label="Mostrar contraseña"
                title="Mostrar contraseña"
                aria-pressed="false"
              >
                <svg
                  data-password-show-icon
                  aria-hidden="true"
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path>
                  <circle cx="12" cy="12" r="3"></circle>
                </svg>
                <svg
                  data-password-hide-icon
                  aria-hidden="true"
                  class="hidden"
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M10.733 5.076A10.744 10.744 0 0 1 12 5c7 0 10 7 10 7a13.163 13.163 0 0 1-1.67 2.68"></path>
                  <path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"></path>
                  <path d="M2 2l20 20"></path>
                  <path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"></path>
                </svg>
              </button>
            </div>
            <span
              id="access-password-error"
              class="hidden text-sm text-red-600"
            >
              Indica tu contraseña.
            </span>
          </label>

          <div
            class="flex flex-col gap-3 pt-2 sm:col-span-2 sm:flex-row sm:items-center"
          >
            <button
              id="access-submit"
              type="submit"
              class="inline-flex min-h-11 cursor-pointer items-center justify-center rounded-md bg-accent px-8 py-3 text-base font-bold uppercase text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent disabled:cursor-not-allowed disabled:opacity-70"
            >
              <span data-label-idle>Ver mi casillero</span>
              <span
                data-label-loading
                class="hidden"
              >
                Consultando...
              </span>
            </button>
            <p
              id="access-status"
              class="text-sm text-text-muted"
              aria-live="polite"
            >
            </p>
          </div>
        </form>
      </div>

      <div
        id="locker-content"
        class="hidden"
      >
        <article
          class="mx-auto max-w-4xl overflow-hidden rounded-xl border border-border bg-background shadow-xl shadow-primary/10"
          aria-labelledby="locker-card-title"
        >
          <header class="bg-primary px-6 py-6 text-primary-fg sm:px-8">
            <div
              class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between"
            >
              <div class="rounded-md bg-white px-3 py-2 shadow-sm">
                <Logo />
              </div>
              <div class="sm:text-right">
                <p
                  id="locker-card-title"
                  class="font-heading text-2xl font-bold uppercase tracking-wide"
                >
                  Carnet de casillero
                </p>
                <span
                  class="mt-3 inline-flex rounded-full border border-primary-fg/30 bg-green-600 shadow-sm shadow-green-400 px-3 py-1 text-xs font-bold uppercase tracking-wide text-primary-fg"
                >
                  Casillero activo
                </span>
              </div>
            </div>
          </header>

          <div class="bg-surface px-6 py-8 sm:px-8 lg:px-10">
            <section
              class="grid grid-cols-1 gap-6 border-b border-border pb-8 lg:grid-cols-[1.15fr_0.85fr] lg:items-end"
              aria-labelledby="locker-owner-title"
            >
              <div>
                <p
                  id="locker-owner-title"
                  class="text-xs font-bold uppercase tracking-wider text-accent"
                >
                  Nombre del cliente
                </p>
                <h2
                  id="card-customer-name"
                  class="mt-3 font-heading text-3xl font-bold text-text sm:text-4xl"
                >
                </h2>
                <div class="mt-6 w-full md:max-w-2xl">
                  <p
                    class="mb-2 text-xs font-bold uppercase tracking-wider text-text-muted"
                  >
                    Código de cliente
                  </p>
                  <p
                    id="shipping-warehouse_reference"
                    class="mt-1 break-words rounded-md border-l-4 border-accent bg-background px-4 py-3 font-heading text-lg font-bold text-primary"
                  >
                  </p>
                </div>
              </div>
              <div
                class="rounded-lg border border-primary/15 bg-background p-5 shadow-sm"
              >
                <p
                  class="text-xs font-bold uppercase tracking-wider text-text-muted"
                >
                  N.º de casillero
                </p>
                <p
                  id="card-locker-code"
                  class="mt-2 break-words font-heading text-5xl font-black leading-none text-primary sm:text-6xl"
                >
                </p>
              </div>
            </section>

            <section
              class="grid grid-cols-1 gap-8 py-8 lg:grid-cols-[1fr_1.05fr]"
              aria-labelledby="shipping-data-title"
            >
              <div>
                <h2
                  id="shipping-data-title"
                  class="font-heading text-2xl font-bold text-text"
                >
                  Datos para compras y envíos
                </h2>
                <p class="mt-3 leading-relaxed text-text-muted">
                  Usa estos datos exactamente como aparecen al comprar en
                  tiendas de Estados Unidos o al enviar paquetes al almacén en
                  Miami.
                </p>
              </div>

              <div
                class="rounded-lg border border-border bg-background p-6 shadow-sm"
                aria-labelledby="postal-block-title"
              >
                <p
                  id="postal-block-title"
                  class="text-xs font-bold uppercase tracking-wider text-accent"
                >
                  Dirección de su warehouse en CaricoXpress
                </p>
                <div
                  class="mt-4 rounded-md bg-primary px-5 py-5 font-mono text-base leading-8 text-primary-fg shadow-inner sm:text-lg"
                >
                  <p
                    id="postal-address_line_1"
                    class="break-words"
                  >
                  </p>
                  <p>
                    <span id="postal-city"></span><span id="postal-city-comma">
                      ,
                    </span><span id="postal-state"></span>
                    <span id="postal-postal_code"></span>
                  </p>
                  <p id="postal-country"></p>
                </div>
              </div>
            </section>
          </div>

          <footer
            class="flex flex-col gap-3 border-t border-border pt-6 sm:flex-row sm:flex-wrap sm:items-center sm:justify-end"
          >
            <button
              id="close-locker"
              type="button"
              class="inline-flex min-h-11 cursor-pointer mx-4 my-0 md:m-4 items-center justify-center rounded-md border border-border px-5 py-3 text-sm font-bold text-text transition-colors hover:bg-background focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="1.5em"
                height="1.5em"
                viewBox="0 0 24 24"
              >
                <path
                  d="M0 0h24v24H0z"
                  fill="none"
                >
                </path>
                <path
                  fill="currentColor"
                  d="m17 8l-1.41 1.41L17.17 11H9v2h8.17l-1.58 1.58L17 16l4-4zM5 5h7V3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h7v-2H5z"
                >
                </path>
              </svg>

              Cerrar casillero
            </button>
          </footer>
        </article>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
<script>
  (() => {
    interface ShippingData {
      warehouse_reference: string;
      address_line_1: string;
      city: string;
      state: string;
      postal_code: string;
      country: string;
    }

    interface LockerAccessResponse {
      customer_name: string;
      locker_code: string;
      shipping_data: ShippingData;
    }

    const publicApiUrl = import.meta.env.PUBLIC_API_URL;
    const accessEndpoint = publicApiUrl
      ? `${publicApiUrl.replace(/\/$/, "")}/api/public/locker-access`
      : "";
    const invalidCredentialsMessage =
      "El correo o la contraseña no son correctos.";
    const rateLimitMessage =
      "Has realizado varios intentos en poco tiempo. Espera un momento antes de intentar nuevamente.";
    const genericErrorMessage =
      "No pudimos consultar tu casillero en este momento. Intenta nuevamente más tarde.";

    const accessPanel = document.getElementById("access-panel");
    const form = document.getElementById("locker-access-form");
    const submitButton = document.getElementById("access-submit");
    const status = document.getElementById("access-status");
    const accessError = document.getElementById("access-error");
    const successMessage = document.getElementById(
      "registration-success-message",
    );
    const idleLabel = form?.querySelector("[data-label-idle]");
    const loadingLabel = form?.querySelector("[data-label-loading]");
    const content = document.getElementById("locker-content");
    const cardCustomerName = document.getElementById("card-customer-name");
    const cardLockerCode = document.getElementById("card-locker-code");
    const closeLockerButton = document.getElementById("close-locker");

    if (!(form instanceof HTMLFormElement)) return;
    if (!(submitButton instanceof HTMLButtonElement)) return;

    const initializePasswordToggles = () => {
      document
        .querySelectorAll("[data-password-toggle]")
        .forEach((toggle: Element) => {
          if (!(toggle instanceof HTMLButtonElement)) return;
          if (toggle.dataset.passwordToggleInitialized === "true") return;

          const inputId = toggle.dataset.passwordToggle;
          if (!inputId) return;

          const input = document.getElementById(inputId);
          if (!(input instanceof HTMLInputElement)) return;

          const showIcon = toggle.querySelector("[data-password-show-icon]");
          const hideIcon = toggle.querySelector("[data-password-hide-icon]");

          const updateToggleState = (isVisible: boolean) => {
            toggle.setAttribute(
              "aria-label",
              isVisible ? "Ocultar contraseña" : "Mostrar contraseña",
            );
            toggle.setAttribute(
              "title",
              isVisible ? "Ocultar contraseña" : "Mostrar contraseña",
            );
            toggle.setAttribute("aria-pressed", isVisible ? "true" : "false");
            showIcon?.classList.toggle("hidden", isVisible);
            hideIcon?.classList.toggle("hidden", !isVisible);
          };

          toggle.addEventListener("click", () => {
            const shouldShowPassword = input.type === "password";
            input.type = shouldShowPassword ? "text" : "password";
            updateToggleState(shouldShowPassword);
          });

          updateToggleState(input.type === "text");
          toggle.dataset.passwordToggleInitialized = "true";
        });
    };

    initializePasswordToggles();

    if (
      new URLSearchParams(window.location.search).get("registro") === "exitoso"
    ) {
      successMessage?.classList.remove("hidden");
    }

    const setLoading = (isLoading: boolean) => {
      submitButton.disabled = isLoading;
      idleLabel?.classList.toggle("hidden", isLoading);
      loadingLabel?.classList.toggle("hidden", !isLoading);
      if (status) {
        status.textContent = isLoading ? "Consultando..." : "";
      }
    };

    const setError = (message: string) => {
      if (accessError) {
        accessError.textContent = message;
        accessError.classList.remove("hidden");
      }
    };

    const clearErrors = () => {
      accessError?.classList.add("hidden");
      form.querySelectorAll('[id$="-error"]').forEach((error: Element) => {
        error.classList.add("hidden");
      });
      form.querySelectorAll("[aria-invalid]").forEach((field: Element) => {
        field.removeAttribute("aria-invalid");
      });
    };

    const showNativeFieldErrors = () => {
      const fields = form.querySelectorAll("input");
      fields.forEach((field: Element) => {
        if (!(field instanceof HTMLInputElement)) return;
        if (field.validity.valid) return;
        field.setAttribute("aria-invalid", "true");
        document
          .getElementById(`${field.id}-error`)
          ?.classList.remove("hidden");
      });
    };

    const readJsonResponse = async (
      response: Response,
    ): Promise<unknown | null> => {
      try {
        return await response.json();
      } catch {
        return null;
      }
    };

    const isRecord = (value: unknown): value is Record<string, unknown> =>
      value !== null && typeof value === "object";
    const isString = (value: unknown): value is string =>
      typeof value === "string";
    const hasString = (value: unknown): value is string =>
      isString(value) && value.trim().length > 0;

    const isValidShippingData = (value: unknown): value is ShippingData => {
      if (!isRecord(value)) return false;

      return (
        hasString(value.warehouse_reference) &&
        hasString(value.address_line_1) &&
        hasString(value.city) &&
        hasString(value.state) &&
        hasString(value.postal_code) &&
        hasString(value.country)
      );
    };

    const isValidLockerResponse = (
      data: unknown,
    ): data is LockerAccessResponse => {
      if (!isRecord(data)) return false;
      if (!hasString(data.customer_name) || !hasString(data.locker_code)) {
        return false;
      }
      if (!isValidShippingData(data.shipping_data)) return false;

      return true;
    };

    const setText = (id: string, value: unknown) => {
      const element = document.getElementById(id);
      if (element) {
        element.textContent = typeof value === "string" ? value : "";
      }
    };

    const renderLocker = (data: LockerAccessResponse) => {
      const shippingData = data.shipping_data;

      if (cardCustomerName) {
        cardCustomerName.textContent = data.customer_name;
      }
      if (cardLockerCode) {
        cardLockerCode.textContent = data.locker_code;
      }

      setText("shipping-warehouse_reference", shippingData.warehouse_reference);
      setText("postal-address_line_1", shippingData.address_line_1);
      setText("postal-city", shippingData.city);
      setText("postal-state", shippingData.state);
      setText("postal-postal_code", shippingData.postal_code);
      setText("postal-country", shippingData.country);

      accessPanel?.classList.add("hidden");
      content?.classList.remove("hidden");
    };

    form.addEventListener("submit", async (event: Event) => {
      event.preventDefault();
      if (submitButton.disabled) return;

      clearErrors();

      if (!form.checkValidity()) {
        showNativeFieldErrors();
        return;
      }

      if (!accessEndpoint) {
        setError(genericErrorMessage);
        return;
      }

      const emailField = form.elements.namedItem("email");
      const passwordField = form.elements.namedItem("password");
      if (!(emailField instanceof HTMLInputElement)) return;
      if (!(passwordField instanceof HTMLInputElement)) return;

      setLoading(true);

      try {
        const response = await fetch(accessEndpoint, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify({
            email: emailField.value,
            password: passwordField.value,
          }),
        });

        if (response.status === 401) {
          setError(invalidCredentialsMessage);
          setLoading(false);
          return;
        }

        if (response.status === 429) {
          setError(rateLimitMessage);
          setLoading(false);
          return;
        }

        if (!response.ok) {
          setError(genericErrorMessage);
          setLoading(false);
          return;
        }

        const data = await readJsonResponse(response);
        if (!isValidLockerResponse(data)) {
          setError(genericErrorMessage);
          setLoading(false);
          return;
        }

        renderLocker(data);
      } catch {
        setError(genericErrorMessage);
        setLoading(false);
      }
    });

    closeLockerButton?.addEventListener("click", () => {
      window.location.replace("/mi-casillero");
    });
  })();
</script>

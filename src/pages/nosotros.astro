---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Banner from "../components/Banner.astro";
import CTA from "../components/CTA.astro";
import {Image} from "astro:assets";
import {brand} from "../config/brand";

import imagenNosotros from "../assets/images/about/nosotros.png";

const team = [
  {
    name: "Maria Garcia",
    role: "CEO & Fundadora",
    image:
      "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=400&q=80",
  },
  {
    name: "Tony Pérez",
    role: "Gerente de almacén",
    image:
      "https://images.unsplash.com/photo-1472099645785-5658abf4ff4e?w=400&q=80",
  },
  {
    name: "David Suárez",
    role: "Gerente de operaciones",
    image:
      "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=400&q=80",
  },
];
---

<BaseLayout
  title="Nosotros"
  description={`Aprenda sobre ${brand.name} — nuestra historia, equipo y compromiso con el servicio de calidad.`}
>
  <Header slot="header" />

  <Banner title="Acerca de" />

  <!-- Story -->
  <section class="py-section">
    <div
      class="mx-auto grid max-w-site grid-cols-1 items-center gap-8 px-4 sm:px-6 lg:grid-cols-2 lg:gap-14"
    >
      <div class="overflow-hidden rounded-lg shadow-lg">
        <Image
          src={imagenNosotros}
          alt="Nuestro equipo trabajando en el almacén de envíos"
          width={700}
          height={900}
          loading="lazy"
          class="size-full object-cover"
        />
      </div>
      <div class="space-y-5">
        <span
          class="text-topper font-bold uppercase tracking-widest text-accent"
        >
          Nuestra Historia
        </span>
        <h2 class="font-heading text-h2 font-bold uppercase text-text">
          Haciendo posible cada envío exitoso desde 2015
        </h2>
        <p class="text-text-muted leading-relaxed">
          Lo que comenzó como una solución logística enfocada en acortar
          distancias se ha transformado en un equipo comprometido y confiable.
          Nos especializamos en la gestión integral de envíos aéreos express,
          carga marítima consolidada y asignación de casilleros internacionales,
          asegurando que cada paquete llegue a su destino en Venezuela en tiempo
          récord.
        </p>
        <p class="text-text-muted leading-relaxed">
          Sabemos que detrás de cada carga hay un esfuerzo, un negocio o un lazo
          familiar. Por eso, tratamos tu mercancía con la máxima seguridad,
          transparencia y el cuidado que merece, respaldando cada servicio con
          un control de inventario estricto y asesoría personalizada en todo el
          proceso aduanal.
        </p>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="bg-surface py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center">
        <span
          class="text-topper font-bold uppercase tracking-widest text-accent"
        >
          Nuestro Equipo
        </span>
        <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">
          Conoce al equipo que lo hace posible
        </h2>
      </div>

      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {
          team.map(({name, role, image}) => (
            <div class="overflow-hidden rounded-lg bg-background shadow-sm">
              <Image
                src={image}
                alt={name}
                width={400}
                height={400}
                loading="lazy"
                class="aspect-square w-full object-cover"
              />
              <div class="p-5">
                <h3 class="font-heading text-lg font-semibold text-text">
                  {name}
                </h3>
                <p class="text-sm text-text-muted">{role}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <CTA />

  <Footer slot="footer" />
</BaseLayout>

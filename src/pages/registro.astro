---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Banner from "../components/Banner.astro";

const steps = [
  {
    number: "1",
    title: "Completa tus datos",
    description:
      "Registra la información básica necesaria para solicitar tu casillero CaricoXpress.",
  },
  {
    number: "2",
    title: "Verifica tu correo",
    description:
      "Te enviaremos un enlace para confirmar que el correo pertenece a ti.",
  },
  {
    number: "3",
    title: "Recibe tu casillero",
    description:
      "Al completar la verificación, recibirás los datos para enviar tus compras a Miami.",
  },
];

const fieldClass =
  "min-h-11 rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20";

const errorClass = "hidden text-sm text-red-600";

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;

const venezuelanStates = [
  "Amazonas",
  "Anzoátegui",
  "Apure",
  "Aragua",
  "Barinas",
  "Bolívar",
  "Carabobo",
  "Cojedes",
  "Delta Amacuro",
  "Distrito Capital",
  "Falcón",
  "Guárico",
  "La Guaira",
  "Lara",
  "Mérida",
  "Miranda",
  "Monagas",
  "Nueva Esparta",
  "Portuguesa",
  "Sucre",
  "Táchira",
  "Trujillo",
  "Yaracuy",
  "Zulia",
];
---

<BaseLayout
  title="Crear casillero CaricoXpress"
  description="Solicita tu casillero internacional CaricoXpress para recibir compras en Miami y coordinar envíos hacia Venezuela."
>
  <Fragment slot="head">
    <script
      src="https://challenges.cloudflare.com/turnstile/v0/api.js"
      async
      defer
    ></script>
  </Fragment>

  <Header slot="header" />

  <Banner title="Crear casillero internacional" />

  <section class="bg-background py-section">
    <div
      class="mx-auto grid max-w-site grid-cols-1 gap-10 px-4 sm:px-6 lg:grid-cols-5 lg:gap-14"
    >
      <aside class="lg:col-span-2">
        <div class="sticky top-24">
          <p class="text-sm font-bold uppercase text-accent">
            Registro público
          </p>
          <h2 class="mt-3 font-heading text-h2 font-bold uppercase text-text">
            Compra en Miami con una dirección propia
          </h2>
          <p class="mt-4 leading-relaxed text-text-muted">
            Solicita tu casillero para recibir compras de tiendas
            internacionales y preparar tus envíos hacia Venezuela con el equipo
            de CaricoXpress.
          </p>

          <ol class="mt-8 space-y-5">
            {
              steps.map((step) => (
                <li class="flex gap-4">
                  <span class="flex size-10 shrink-0 items-center justify-center rounded-md bg-primary text-sm font-bold text-primary-fg">
                    {step.number}
                  </span>
                  <div>
                    <h3 class="font-heading text-lg font-semibold text-text">
                      {step.title}
                    </h3>
                    <p class="mt-1 text-sm leading-relaxed text-text-muted">
                      {step.description}
                    </p>
                  </div>
                </li>
              ))
            }
          </ol>

          <div class="mt-8 rounded-lg border border-border bg-surface p-5">
            <h3 class="font-heading text-lg font-semibold text-text">
              Antes de empezar
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-text-muted">
              Usa datos reales y un correo al que tengas acceso. Ese correo será
              necesario para completar el registro cuando la verificación esté
              activa.
            </p>
          </div>
        </div>
      </aside>

      <div class="lg:col-span-3">
        <div class="rounded-lg border border-border bg-background p-6 shadow-sm sm:p-8">
          <div class="mb-8">
            <h2 class="font-heading text-h2 font-bold uppercase text-text">
              Datos del solicitante
            </h2>
            <p class="mt-2 text-text-muted">
              Completa el formulario para dejar lista tu solicitud de casillero.
            </p>
          </div>

          <form
            id="public-registration-form"
            class="grid grid-cols-1 gap-5 sm:grid-cols-2"
            novalidate
          >
            <label
              for="first_name"
              class="flex flex-col gap-1.5"
            >
              <span class="text-sm font-medium text-text">
                Nombre <span
                  class="text-accent"
                  aria-hidden="true"
                >
                  *
                </span>
              </span>
              <input
                id="first_name"
                name="first_name"
                type="text"
                autocomplete="given-name"
                required
                class={fieldClass}
                aria-describedby="first_name-error"
              />
              <span
                id="first_name-error"
                class={errorClass}
              >
                Indica tu nombre.
              </span>
            </label>

            <label
              for="last_name"
              class="flex flex-col gap-1.5"
            >
              <span class="text-sm font-medium text-text">
                Apellido <span
                  class="text-accent"
                  aria-hidden="true"
                >
                  *
                </span>
              </span>
              <input
                id="last_name"
                name="last_name"
                type="text"
                autocomplete="family-name"
                required
                class={fieldClass}
                aria-describedby="last_name-error"
              />
              <span
                id="last_name-error"
                class={errorClass}
              >
                Indica tu apellido.
              </span>
            </label>

            <label
              for="document_type"
              class="flex flex-col gap-1.5"
            >
              <span class="text-sm font-medium text-text">
                Tipo de documento <span
                  class="text-accent"
                  aria-hidden="true"
                >
                  *
                </span>
              </span>
              <select
                id="document_type"
                name="document_type"
                required
                class={fieldClass}
                aria-describedby="document_type-error"
              >
                <option
                  value=""
                  selected
                  disabled
                >
                  Selecciona
                </option>
                <option value="V">V</option>
                <option value="E">E</option>
                <option value="J">J</option>
                <option value="P">P</option>
              </select>
              <span
                id="document_type-error"
                class={errorClass}
              >
                Selecciona el tipo de documento.
              </span>
            </label>

            <label
              for="document_number"
              class="flex flex-col gap-1.5"
            >
              <span class="text-sm font-medium text-text">
                Número de documento <span
                  class="text-accent"
                  aria-hidden="true"
                >
                  *
                </span>
              </span>
              <input
                id="document_number"
                name="document_number"
                type="text"
                autocomplete="off"
                inputmode="text"
                required
                class={fieldClass}
                aria-describedby="document_number-error"
              />
              <span
                id="document_number-error"
                class={errorClass}
              >
                Indica tu número de documento.
              </span>
            </label>

            <label
              for="phone"
              class="flex flex-col gap-1.5"
            >
              <span class="text-sm font-medium text-text">
                Teléfono <span
                  class="text-accent"
                  aria-hidden="true"
                >
                  *
                </span>
              </span>
              <input
                id="phone"
                name="phone"
                type="tel"
                autocomplete="tel"
                inputmode="tel"
                required
                class={fieldClass}
                aria-describedby="phone-error"
              />
              <span
                id="phone-error"
                class={errorClass}
              >
                Indica un teléfono de contacto.
              </span>
            </label>

            <label
              for="whatsapp"
              class="flex flex-col gap-1.5"
            >
              <span class="text-sm font-medium text-text">
                WhatsApp <span
                  class="text-accent"
                  aria-hidden="true"
                >
                  *
                </span>
              </span>
              <input
                id="whatsapp"
                name="whatsapp"
                type="tel"
                autocomplete="tel"
                inputmode="tel"
                required
                class={fieldClass}
                aria-describedby="whatsapp-error"
              />
              <span
                id="whatsapp-error"
                class={errorClass}
              >
                Indica tu numero de WhatsApp.
              </span>
            </label>

            <label
              for="email"
              class="flex flex-col gap-1.5 sm:col-span-2"
            >
              <span class="text-sm font-medium text-text">
                Correo electrónico <span
                  class="text-accent"
                  aria-hidden="true"
                >
                  *
                </span>
              </span>
              <input
                id="email"
                name="email"
                type="email"
                autocomplete="email"
                inputmode="email"
                required
                class={fieldClass}
                aria-describedby="email-error"
              />
              <span
                id="email-error"
                class={errorClass}
              >
                Indica un correo electrónico válido.
              </span>
            </label>

            <label
              for="address"
              class="flex flex-col gap-1.5 sm:col-span-2"
            >
              <span class="text-sm font-medium text-text">
                Dirección en Venezuela <span
                  class="text-accent"
                  aria-hidden="true"
                >
                  *
                </span>
              </span>
              <textarea
                id="address"
                name="address"
                autocomplete="street-address"
                required
                rows="3"
                class={`${fieldClass} min-h-28 resize-y`}
                aria-describedby="address-error"
              ></textarea>
              <span
                id="address-error"
                data-error-for="address"
                class={errorClass}
              >
                Indica tu dirección en Venezuela.
              </span>
            </label>

            <label
              for="city"
              class="flex flex-col gap-1.5"
            >
              <span class="text-sm font-medium text-text">
                Ciudad <span
                  class="text-accent"
                  aria-hidden="true"
                >
                  *
                </span>
              </span>
              <input
                id="city"
                name="city"
                type="text"
                autocomplete="address-level2"
                required
                class={fieldClass}
                aria-describedby="city-error"
              />
              <span
                id="city-error"
                data-error-for="city"
                class={errorClass}
              >
                Indica tu ciudad.
              </span>
            </label>

            <label
              for="state"
              class="flex flex-col gap-1.5"
            >
              <span class="text-sm font-medium text-text">
                Estado <span
                  class="text-accent"
                  aria-hidden="true"
                >
                  *
                </span>
              </span>
              <select
                id="state"
                name="state"
                autocomplete="address-level1"
                required
                class={fieldClass}
                aria-describedby="state-error"
              >
                <option
                  value=""
                  selected
                  disabled
                >
                  Selecciona un estado
                </option>
                {
                  venezuelanStates.map((state) => (
                    <option value={state}>{state}</option>
                  ))
                }
              </select>
              <span
                id="state-error"
                data-error-for="state"
                class={errorClass}
              >
                Selecciona un estado.
              </span>
            </label>

            <div class="border-t border-border pt-5 sm:col-span-2">
              <h3 class="font-heading text-h3 font-semibold text-text">
                Acceso a tu casillero
              </h3>
              <p class="mt-2 text-sm leading-relaxed text-text-muted">
                Crea una contraseña para consultar nuevamente los datos de tu
                casillero cuando los necesites.
              </p>
            </div>

            <label
              for="password"
              class="flex flex-col gap-1.5"
            >
              <span class="text-sm font-medium text-text">
                Contraseña <span
                  class="text-accent"
                  aria-hidden="true"
                >
                  *
                </span>
              </span>
              <input
                id="password"
                name="password"
                type="password"
                autocomplete="new-password"
                required
                minlength="8"
                class={fieldClass}
                aria-describedby="password-error"
              />
              <span
                id="password-error"
                data-error-for="password"
                class={errorClass}
              >
                Indica una contraseña de al menos 8 caracteres.
              </span>
            </label>

            <label
              for="password_confirmation"
              class="flex flex-col gap-1.5"
            >
              <span class="text-sm font-medium text-text">
                Confirmar contraseña <span
                  class="text-accent"
                  aria-hidden="true"
                >
                  *
                </span>
              </span>
              <input
                id="password_confirmation"
                name="password_confirmation"
                type="password"
                autocomplete="new-password"
                required
                minlength="8"
                class={fieldClass}
                aria-describedby="password_confirmation-error"
              />
              <span
                id="password_confirmation-error"
                data-error-for="password_confirmation"
                class={errorClass}
              >
                Confirma tu contraseña.
              </span>
            </label>

            <div class="sm:col-span-2">
              <div
                class="cf-turnstile"
                data-sitekey={turnstileSiteKey}
                data-response-field-name="turnstile_token"
                data-theme="light"
                data-size="flexible"
                data-language="es"
              >
              </div>
            </div>

            <div
              id="registration-general-error"
              class="hidden rounded-md border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700 sm:col-span-2"
              role="alert"
            >
              No pudimos procesar la solicitud. Revisa los campos e intenta
              nuevamente.
            </div>

            <div
              id="registration-success"
              class="hidden rounded-md border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700 sm:col-span-2"
              role="status"
            >
              Revisa tu correo para continuar con la verificación.
            </div>

            <div class="flex flex-col gap-3 pt-2 sm:col-span-2 sm:flex-row sm:items-center">
              <button
                id="registration-submit"
                type="submit"
                class="inline-flex min-h-11 cursor-pointer items-center justify-center rounded-md bg-accent px-8 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent disabled:cursor-not-allowed disabled:opacity-70"
              >
                <span data-label-idle>Crear mi casillero</span>
                <span
                  data-label-loading
                  class="hidden"
                >
                  Enviando solicitud
                </span>
              </button>
              <p
                id="registration-status"
                class="text-sm text-text-muted"
                aria-live="polite"
              >
              </p>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script>
  (() => {
    const publicApiUrl = import.meta.env.PUBLIC_API_URL;
    const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
    const registrationEndpoint = publicApiUrl
      ? `${publicApiUrl.replace(/\/$/, "")}/api/public/registrations`
      : "";
    const genericErrorMessage =
      "No pudimos procesar la solicitud. Intenta nuevamente en unos minutos.";
    const configurationErrorMessage =
      "No pudimos procesar tu registro en este momento. Intenta nuevamente más tarde.";
    const missingTurnstileMessage =
      "Confirma que eres humano antes de continuar.";
    const rateLimitMessage =
      "Has realizado varios intentos en poco tiempo. Espera un momento antes de intentar nuevamente.";

    const form = document.getElementById("public-registration-form");
    if (!(form instanceof HTMLFormElement)) return;
    if (form.dataset.registrationInit === "true") return;
    form.dataset.registrationInit = "true";

    const submitButton = document.getElementById("registration-submit");
    const status = document.getElementById("registration-status");
    const generalError = document.getElementById("registration-general-error");
    const success = document.getElementById("registration-success");
    const idleLabel = form.querySelector("[data-label-idle]");
    const loadingLabel = form.querySelector("[data-label-loading]");

    const setGeneralErrorMessage = (message) => {
      if (generalError) {
        generalError.textContent = message;
      }
    };

    const setFormState = (state) => {
      const isLoading = state === "loading";
      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = isLoading;
      }
      idleLabel?.classList.toggle("hidden", isLoading);
      loadingLabel?.classList.toggle("hidden", !isLoading);
      generalError?.classList.toggle("hidden", state !== "error");
      success?.classList.toggle("hidden", state !== "success");
      if (status) {
        status.textContent = isLoading ? "Preparando solicitud..." : "";
      }
    };

    const clearFieldErrors = () => {
      form.querySelectorAll('[id$="-error"]').forEach((error) => {
        error.classList.add("hidden");
      });
      form.querySelectorAll("[aria-invalid]").forEach((field) => {
        field.removeAttribute("aria-invalid");
      });
    };

    const getField = (name) => {
      const field = form.elements.namedItem(name);
      return field instanceof HTMLInputElement ||
        field instanceof HTMLSelectElement ||
        field instanceof HTMLTextAreaElement
        ? field
        : null;
    };

    const showFieldError = (name, message) => {
      if (name === "turnstile_token") {
        setGeneralErrorMessage(message);
        return;
      }

      const field = getField(name);
      if (!field) return;

      field.setAttribute("aria-invalid", "true");
      const error = document.getElementById(`${field.id}-error`);
      const dataError = form.querySelector(`[data-error-for="${field.name}"]`);
      const errorElement = dataError ?? error;
      if (!(errorElement instanceof HTMLElement)) return;
      errorElement.textContent = message;
      errorElement.classList.remove("hidden");
    };

    const showNativeFieldErrors = () => {
      const fields = form.querySelectorAll("input, select, textarea");
      fields.forEach((field) => {
        if (
          !(
            field instanceof HTMLInputElement ||
            field instanceof HTMLSelectElement ||
            field instanceof HTMLTextAreaElement
          )
        ) {
          return;
        }
        if (field.validity.valid) return;
        field.setAttribute("aria-invalid", "true");
        const error = document.getElementById(`${field.id}-error`);
        const dataError = form.querySelector(`[data-error-for="${field.name}"]`);
        const errorElement = dataError ?? error;
        errorElement?.classList.remove("hidden");
      });
    };

    const collectRegistrationPayload = () => {
      const formData = new FormData(form);
      const turnstileToken = formData.get("turnstile_token");

      return {
        first_name: getField("first_name")?.value ?? "",
        last_name: getField("last_name")?.value ?? "",
        document_type: getField("document_type")?.value ?? "",
        document_number: getField("document_number")?.value ?? "",
        phone: getField("phone")?.value ?? "",
        whatsapp: getField("whatsapp")?.value ?? "",
        email: getField("email")?.value ?? "",
        address: getField("address")?.value ?? "",
        city: getField("city")?.value ?? "",
        state: getField("state")?.value ?? "",
        password: getField("password")?.value ?? "",
        password_confirmation:
          getField("password_confirmation")?.value ?? "",
        turnstile_token:
          typeof turnstileToken === "string" ? turnstileToken : "",
      };
    };

    const resetTurnstile = () => {
      const turnstile = window.turnstile;
      if (turnstile && typeof turnstile.reset === "function") {
        turnstile.reset();
      }
    };

    const readJsonResponse = async (response) => {
      try {
        return await response.json();
      } catch {
        return null;
      }
    };

    const showValidationErrors = (errors) => {
      if (!errors || typeof errors !== "object") return false;

      let hasFieldError = false;
      Object.entries(errors).forEach(([field, messages]) => {
        if (!Array.isArray(messages)) return;
        const [message] = messages;
        if (typeof message !== "string" || message.length === 0) return;

        showFieldError(field, message);
        hasFieldError = true;
      });

      return hasFieldError;
    };

    const submitRegistration = async (payload) => {
      if (!registrationEndpoint) {
        setGeneralErrorMessage(genericErrorMessage);
        setFormState("error");
        return false;
      }

      try {
        const response = await fetch(registrationEndpoint, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            Accept: "application/json",
          },
          body: JSON.stringify(payload),
        });

        if (response.status === 202) {
          setFormState("success");
          return true;
        }

        if (response.status === 422) {
          const data = await readJsonResponse(response);
          const hasFieldError = showValidationErrors(data?.errors);
          const turnstileErrors = data?.errors?.turnstile_token;
          const turnstileMessage = Array.isArray(turnstileErrors)
            ? turnstileErrors.find((message) => typeof message === "string")
            : "";
          if (turnstileMessage) {
            setGeneralErrorMessage(turnstileMessage);
          } else {
            setGeneralErrorMessage(
              hasFieldError
                ? "Revisa los campos marcados e intenta nuevamente."
                : genericErrorMessage,
            );
          }
          setFormState("error");
          resetTurnstile();
          return false;
        }

        if (response.status === 429) {
          setGeneralErrorMessage(rateLimitMessage);
          setFormState("error");
          resetTurnstile();
          return false;
        }

        console.error("Unexpected registration response", response.status);
        setGeneralErrorMessage(genericErrorMessage);
        setFormState("error");
        resetTurnstile();
        return false;
      } catch (error) {
        console.error("Registration request failed", error);
        setGeneralErrorMessage(genericErrorMessage);
        setFormState("error");
        resetTurnstile();
        return false;
      }
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (submitButton instanceof HTMLButtonElement && submitButton.disabled) return;

      clearFieldErrors();
      setFormState("idle");

      if (!form.checkValidity()) {
        showNativeFieldErrors();
        return;
      }

      const payload = collectRegistrationPayload();
      if (!turnstileSiteKey) {
        setGeneralErrorMessage(configurationErrorMessage);
        setFormState("error");
        return;
      }
      if (!payload.turnstile_token) {
        setGeneralErrorMessage(missingTurnstileMessage);
        setFormState("error");
        return;
      }

      setFormState("loading");
      await submitRegistration(payload);
    });
  })();
</script>

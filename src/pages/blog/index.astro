---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Banner from "../../components/Banner.astro";
import CTA from "../../components/CTA.astro";
import {Image} from "astro:assets";
import {getCollection} from "astro:content";
import {seo} from "../../config/seo";

import cargaEmprendedores from "../../assets/images/gallery/Espacio seguro para sus importaciones.png";
import erroresEnvio from "../../assets/images/gallery/Control y precisión en cada paquete.png";
import guiaEmbalaje from "../../assets/images/gallery/Nuestro personal siempre dispuesto a ayudarle.png";
import comprasSeguras from "../../assets/images/gallery/Maquinaria lista para mover su carga.png";
import aereoMaritimo from "../../assets/images/gallery/Conexión marítima directa con Venezuela.png";
import casilleroMiami from "../../assets/images/gallery/Despachos aéreos express todas las semanas.png";

const posts = (await getCollection("blog", ({data}) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const postImages = {
  "logistica-para-emprendedores-como-abastecer-tu-negocio-en-venezuela": {
    src: cargaEmprendedores,
    alt: "Área segura de almacén para resguardar importaciones y mercancía comercial en Miami",
  },
  "5-errores-comunes-al-enviar-paquetes-a-venezuela-y-como-evitarlos": {
    src: erroresEnvio,
    alt: "Control de paquetes antes de preparar envíos internacionales hacia Venezuela",
  },
  "guia-de-embalaje-protege-tu-carga-antes-del-envio": {
    src: guiaEmbalaje,
    alt: "Personal logístico revisando paquetes para proteger la carga antes del envío",
  },
  "como-comprar-seguro-en-ee-uu-desde-venezuela": {
    src: comprasSeguras,
    alt: "Operación logística preparada para recibir compras realizadas en tiendas de Estados Unidos",
  },
  "envio-aereo-o-maritimo-cual-te-conviene-mas-segun-tu-carga": {
    src: aereoMaritimo,
    alt: "Conexión de carga marítima y logística internacional entre Miami y Venezuela",
  },
  "como-abrir-y-usar-tu-casillero-internacional-en-miami": {
    src: casilleroMiami,
    alt: "Despachos aéreos express organizados para clientes con casillero internacional en Miami",
  },
} as const;
---

<BaseLayout
  title={seo.blog.title}
  description={seo.blog.description}
>
  <Header slot="header" />

  <Banner title="Blog" />

  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      {
        posts.length === 0 ? (
          <p class="text-center text-text-muted">
            Pronto publicaremos nuevas guías de envíos e importaciones.
          </p>
        ) : (
          <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
            {posts.map((post) => {
              const formattedDate = post.data.date.toLocaleDateString("es-VE", {
                year: "numeric",
                month: "long",
                day: "numeric",
              });
              const image =
                postImages[post.id as keyof typeof postImages] ??
                postImages[
                  "logistica-para-emprendedores-como-abastecer-tu-negocio-en-venezuela"
                ];
              const tag = post.data.tags[0] ?? "logística";

              return (
                <article class="group relative flex min-h-full flex-col overflow-hidden rounded-lg border border-border bg-background shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-xl">
                  <a
                    href={`/blog/${post.id}`}
                    class="absolute inset-0 z-10"
                    aria-label={`Leer artículo: ${post.data.title}`}
                  />

                  <div class="relative aspect-16/10 overflow-hidden bg-surface">
                    <Image
                      src={image.src}
                      alt={image.alt}
                      width={640}
                      height={400}
                      loading="lazy"
                      decoding="async"
                      class="size-full object-cover transition-transform duration-500 group-hover:scale-105"
                    />
                    <div class="absolute inset-x-0 bottom-0 h-24 bg-linear-to-t from-dark/70 to-transparent" />
                    <span class="absolute left-4 top-4 rounded-full bg-accent px-3 py-1 text-xs font-bold uppercase tracking-wider text-accent-fg shadow-sm">
                      {tag}
                    </span>
                  </div>

                  <div class="flex flex-1 flex-col p-6">
                    <time
                      datetime={post.data.date.toISOString()}
                      class="text-sm font-medium text-text-muted"
                    >
                      {formattedDate}
                    </time>

                    <h2 class="mt-3 font-heading text-h3 font-semibold text-text transition-colors group-hover:text-primary">
                      {post.data.title}
                    </h2>

                    <p class="mt-3 flex-1 text-sm leading-relaxed text-text-muted">
                      {post.data.description}
                    </p>

                    <span class="mt-5 inline-flex items-center gap-2 text-sm font-bold text-primary transition-colors group-hover:text-accent">
                      Leer guía
                      <svg
                        class="size-4 transition-transform group-hover:translate-x-1"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        aria-hidden="true"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M17 8l4 4m0 0l-4 4m4-4H3"
                        />
                      </svg>
                    </span>
                  </div>
                </article>
              );
            })}
          </div>
        )
      }
    </div>
  </section>

  <CTA />

  <Footer slot="footer" />
</BaseLayout>

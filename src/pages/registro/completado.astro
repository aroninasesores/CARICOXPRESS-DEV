---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Banner from "../../components/Banner.astro";

const shippingFields = [
  ["recipient_name", "Nombre / Recipient"],
  ["locker_code", "Codigo de casillero"],
  ["address_line_1", "Direccion / Address"],
  ["address_line_2", "Address Line 2"],
  ["city", "Ciudad / City"],
  ["state", "Estado / State"],
  ["postal_code", "ZIP Code"],
  ["country", "Pais / Country"],
  ["phone", "Telefono / Phone"],
];
---

<BaseLayout
  title="Carnet virtual CaricoXpress"
  description="Consulta los datos publicos de tu casillero virtual CaricoXpress para compras y envios hacia Miami."
>
  <Fragment slot="head">
    <meta
      name="robots"
      content="noindex, nofollow"
    />
  </Fragment>

  <Header slot="header" />

  <Banner title="Carnet virtual" />

  <section class="bg-background py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <div
        id="locker-loading"
        class="mx-auto max-w-3xl rounded-lg border border-border bg-background p-6 text-center shadow-sm sm:p-8"
        role="status"
        aria-live="polite"
      >
        <p class="text-sm font-bold uppercase text-accent">
          Cargando casillero
        </p>
        <h1 class="mt-3 font-heading text-h2 font-bold uppercase text-text">
          Estamos preparando tu carnet virtual
        </h1>
        <p class="mx-auto mt-4 max-w-2xl leading-relaxed text-text-muted">
          Consultando los datos publicos de tu casillero CaricoXpress.
        </p>
      </div>

      <div
        id="locker-error"
        class="mx-auto hidden max-w-3xl rounded-lg border border-red-200 bg-red-50 p-6 text-center text-red-700 shadow-sm sm:p-8"
        role="alert"
        aria-live="assertive"
        tabindex="-1"
      >
        <p class="text-sm font-bold uppercase">
          No disponible
        </p>
        <h1 class="mt-3 font-heading text-h2 font-bold uppercase">
          No pudimos mostrar tu casillero
        </h1>
        <p
          id="locker-error-message"
          class="mx-auto mt-4 max-w-2xl leading-relaxed"
        >
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <button
            id="retry-locker"
            type="button"
            class="hidden min-h-11 cursor-pointer items-center justify-center rounded-md bg-accent px-8 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent disabled:cursor-not-allowed disabled:opacity-70"
          >
            Intentar nuevamente
          </button>
          <a
            id="start-registration"
            href="/registro"
            class="hidden min-h-11 items-center justify-center rounded-md border-2 border-primary px-8 py-3 text-base font-bold text-primary transition-colors hover:bg-primary/5 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
          >
            Iniciar registro
          </a>
        </div>
      </div>

      <div
        id="locker-content"
        class="hidden"
      >
        <div class="mx-auto max-w-3xl text-center">
          <p class="text-sm font-bold uppercase text-accent">
            Casillero activo
          </p>
          <h1 class="mt-3 font-heading text-h2 font-bold uppercase text-text">
            Tu casillero CaricoXpress esta listo
          </h1>
          <p class="mx-auto mt-4 max-w-2xl leading-relaxed text-text-muted">
            Ya puedes utilizar estos datos al realizar tus compras y envios
            hacia nuestra direccion en Miami.
          </p>
        </div>

        <div class="mt-10 grid grid-cols-1 gap-8 lg:grid-cols-5">
          <div class="lg:col-span-2">
            <div class="overflow-hidden rounded-lg border border-border bg-primary text-primary-fg shadow-sm">
              <div class="border-b border-primary-fg/20 p-6">
                <p class="font-heading text-xl font-bold uppercase">
                  Carico Xpress
                </p>
              </div>
              <div class="p-6">
                <p
                  id="card-customer-name"
                  class="text-sm font-bold uppercase tracking-wider text-primary-fg/70"
                >
                </p>
                <p class="mt-8 text-sm font-bold uppercase text-primary-fg/70">
                  Tu casillero
                </p>
                <p
                  id="card-locker-code"
                  class="mt-2 font-heading text-4xl font-bold uppercase tracking-wide text-primary-fg sm:text-5xl"
                >
                </p>
                <button
                  id="copy-code"
                  type="button"
                  class="mt-6 inline-flex min-h-11 cursor-pointer items-center justify-center rounded-md bg-accent px-6 py-3 text-sm font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
                >
                  Copiar codigo
                </button>
                <p
                  id="copy-code-status"
                  class="mt-3 min-h-5 text-sm text-primary-fg/80"
                  aria-live="polite"
                >
                </p>
              </div>
            </div>

            <div class="mt-6 rounded-lg border border-border bg-surface p-5">
              <h2 class="font-heading text-lg font-semibold text-text">
                Como usar tus identificadores
              </h2>
              <p
                id="warehouse-id-note"
                class="mt-3 text-sm leading-relaxed text-text-muted"
              >
              </p>
              <p
                id="locker-code-note"
                class="mt-2 text-sm leading-relaxed text-text-muted"
              >
              </p>
            </div>
          </div>

          <div class="lg:col-span-3">
            <div class="rounded-lg border border-border bg-background p-6 shadow-sm sm:p-8">
              <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                <div>
                  <h2 class="font-heading text-h3 font-semibold text-text">
                    Datos para comprar y enviar
                  </h2>
                  <p class="mt-2 text-sm leading-relaxed text-text-muted">
                    Utiliza estos datos cuando realices compras en tiendas de
                    Estados Unidos. Tu codigo de casillero permite identificar
                    correctamente tus paquetes al llegar a CaricoXpress.
                  </p>
                </div>
                <button
                  id="copy-shipping"
                  type="button"
                  class="inline-flex min-h-11 shrink-0 cursor-pointer items-center justify-center rounded-md bg-accent px-6 py-3 text-sm font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
                >
                  Copiar datos de envio
                </button>
              </div>
              <p
                id="copy-shipping-status"
                class="mt-3 min-h-5 text-sm text-text-muted"
                aria-live="polite"
              >
              </p>

              <dl class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2">
                {
                  shippingFields.map(([key, label]) => (
                    <div
                      class="rounded-md border border-border bg-surface p-4"
                      data-shipping-row={key}
                    >
                      <dt class="text-xs font-bold uppercase tracking-wider text-text-muted">
                        {label}
                      </dt>
                      <dd
                        id={`shipping-${key}`}
                        class="mt-1 break-words text-base font-semibold text-text"
                      >
                      </dd>
                    </div>
                  ))
                }
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<script>
  (() => {
    const publicApiUrl = import.meta.env.PUBLIC_API_URL;
    const token = new URLSearchParams(window.location.search).get("token")?.trim() ?? "";
    const lockerEndpoint =
      publicApiUrl && token
        ? `${publicApiUrl.replace(/\/$/, "")}/api/public/lockers/${encodeURIComponent(token)}`
        : "";

    const unavailableMessage =
      "No pudimos encontrar los datos de este casillero.";
    const genericErrorMessage =
      "No pudimos cargar los datos de tu casillero en este momento. Intenta nuevamente en unos minutos.";
    const missingTokenMessage =
      "Este enlace no esta disponible. Puedes iniciar nuevamente el registro para recibir un nuevo enlace.";

    const loading = document.getElementById("locker-loading");
    const errorPanel = document.getElementById("locker-error");
    const errorMessage = document.getElementById("locker-error-message");
    const content = document.getElementById("locker-content");
    const retryButton = document.getElementById("retry-locker");
    const startRegistration = document.getElementById("start-registration");
    const cardCustomerName = document.getElementById("card-customer-name");
    const cardLockerCode = document.getElementById("card-locker-code");
    const warehouseIdNote = document.getElementById("warehouse-id-note");
    const lockerCodeNote = document.getElementById("locker-code-note");
    const copyCodeButton = document.getElementById("copy-code");
    const copyCodeStatus = document.getElementById("copy-code-status");
    const copyShippingButton = document.getElementById("copy-shipping");
    const copyShippingStatus = document.getElementById("copy-shipping-status");

    let lockerCode = "";
    let shippingData = null;

    const setPanel = (state) => {
      loading?.classList.toggle("hidden", state !== "loading");
      errorPanel?.classList.toggle("hidden", state !== "error");
      content?.classList.toggle("hidden", state !== "content");
    };

    const focusError = () => {
      if (errorPanel instanceof HTMLElement) {
        errorPanel.focus();
      }
    };

    const setError = (message, action) => {
      if (errorMessage) {
        errorMessage.textContent = message;
      }

      retryButton?.classList.toggle("hidden", action !== "retry");
      retryButton?.classList.toggle("inline-flex", action === "retry");
      startRegistration?.classList.toggle("hidden", action !== "register");
      startRegistration?.classList.toggle("inline-flex", action === "register");
      setPanel("error");
      focusError();
    };

    const isRecord = (value) => value !== null && typeof value === "object";

    const hasString = (value) => typeof value === "string" && value.trim().length > 0;

    const isValidLockerResponse = (data) => {
      if (!isRecord(data) || !isRecord(data.shipping_data)) return false;
      if (!hasString(data.customer_name) || !hasString(data.locker_code)) return false;
      if (!hasString(data.shipping_data.recipient_name)) return false;
      if (!hasString(data.shipping_data.locker_code)) return false;

      return data.locker_code === data.shipping_data.locker_code;
    };

    const readJsonResponse = async (response) => {
      try {
        return await response.json();
      } catch {
        return null;
      }
    };

    const setText = (id, value) => {
      const element = document.getElementById(id);
      if (element) {
        element.textContent = typeof value === "string" ? value : "";
      }
    };

    const setOptionalRow = (key, value) => {
      const row = document.querySelector(`[data-shipping-row="${key}"]`);
      row?.classList.toggle("hidden", !hasString(value));
    };

    const renderLocker = (data) => {
      lockerCode = data.locker_code;
      shippingData = data.shipping_data;

      if (cardCustomerName) {
        cardCustomerName.textContent = data.customer_name;
      }
      if (cardLockerCode) {
        cardLockerCode.textContent = data.locker_code;
      }
      if (warehouseIdNote) {
        warehouseIdNote.textContent = hasString(shippingData.address_line_2)
          ? `${shippingData.address_line_2} identifica a CaricoXpress dentro del almacen en Miami.`
          : "El identificador del almacen debe colocarse cuando este disponible en tus datos de envio.";
      }
      if (lockerCodeNote) {
        lockerCodeNote.textContent = `Tu codigo ${data.locker_code} identifica tus compras y paquetes dentro de CaricoXpress.`;
      }

      [
        "recipient_name",
        "locker_code",
        "address_line_1",
        "address_line_2",
        "city",
        "state",
        "postal_code",
        "country",
        "phone",
      ].forEach((key) => {
        setText(`shipping-${key}`, shippingData[key]);
      });

      setOptionalRow("address_line_2", shippingData.address_line_2);
      setOptionalRow("phone", shippingData.phone);
      setPanel("content");
    };

    const getShippingCopyText = () => {
      if (!shippingData) return "";

      const lines = [
        `${shippingData.recipient_name} - ${shippingData.locker_code}`,
        shippingData.address_line_1,
        shippingData.address_line_2,
        `${shippingData.city}, ${shippingData.state} ${shippingData.postal_code}`.trim(),
        shippingData.country,
        shippingData.phone,
      ];

      return lines.filter((line) => hasString(line)).join("\n");
    };

    const setCopyStatus = (element, message) => {
      if (!element) return;
      element.textContent = message;
      window.setTimeout(() => {
        element.textContent = "";
      }, 3000);
    };

    const copyText = async (text, successMessage, statusElement) => {
      if (!navigator.clipboard || !hasString(text)) {
        setCopyStatus(statusElement, "No pudimos copiar en este momento.");
        return;
      }

      try {
        await navigator.clipboard.writeText(text);
        setCopyStatus(statusElement, successMessage);
      } catch (error) {
        console.error("Clipboard copy failed", error);
        setCopyStatus(statusElement, "No pudimos copiar en este momento.");
      }
    };

    const loadLocker = async () => {
      if (!token) {
        setError(missingTokenMessage, "register");
        return;
      }

      if (!lockerEndpoint) {
        setError(genericErrorMessage, "retry");
        return;
      }

      setPanel("loading");

      try {
        const response = await fetch(lockerEndpoint, {
          method: "GET",
          headers: {
            Accept: "application/json",
          },
        });

        if (response.status === 404) {
          setError(unavailableMessage, "register");
          return;
        }

        if (!response.ok) {
          if (response.status >= 400 && response.status < 500) {
            setError(unavailableMessage, "register");
            return;
          }
          setError(genericErrorMessage, "retry");
          return;
        }

        const data = await readJsonResponse(response);
        if (!isValidLockerResponse(data)) {
          setError(genericErrorMessage, "retry");
          return;
        }

        renderLocker(data);
      } catch (error) {
        console.error("Locker request failed", error);
        setError(genericErrorMessage, "retry");
      }
    };

    retryButton?.addEventListener("click", () => {
      loadLocker();
    });

    copyCodeButton?.addEventListener("click", () => {
      copyText(lockerCode, "Codigo copiado", copyCodeStatus);
    });

    copyShippingButton?.addEventListener("click", () => {
      copyText(getShippingCopyText(), "Datos de envio copiados", copyShippingStatus);
    });

    loadLocker();
  })();
</script>

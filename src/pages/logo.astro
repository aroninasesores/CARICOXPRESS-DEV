---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Propuestas de Logo para Caricoxpress"
  description="Explora las propuestas de logo renderizadas en código para Caricoxpress, cada una con un enfoque único en diseño y simbolismo."
>
  <div class="space-y-12 bg-surface p-10 rounded-lg border border-border my-8">
    <h3 class="text-h3 font-bold text-text mb-6">
      Propuestas de Logo (Renderizadas en código)
    </h3>

    <!-- PROPUESTA 1: Isotipo de Líneas Continuas -->
    <div
      class="flex flex-col gap-2 p-6 bg-background rounded-md border border-border"
    >
      <span class="text-xs font-mono text-text-muted">
        Propuesta 1 (Isotipo + Texto)
      </span>
      <div class="flex items-center gap-3">
        <!-- Isotipo abstracto: C y X entrelazadas con movimiento -->
        <div
          class="relative size-10 flex items-center justify-center bg-primary/10 rounded-sm overflow-hidden"
        >
          <span
            class="absolute left-2 font-heading font-black text-xl text-primary"
          >
            C
          </span>
          <span
            class="absolute right-2 font-heading font-black text-xl text-primary-light transform skew-x-12 translate-x-0.5"
          >
            X
          </span>
          <div
            class="absolute bottom-1 right-1 size-1.5 bg-accent rounded-full"
          >
          </div>
        </div>
        <!-- Tipografía -->
        <div class="font-heading text-2xl tracking-tight">
          <span class="font-black text-primary">CARICO</span><span
            class="font-light text-accent text-primary-light"
          >
            XPRESS
          </span>
        </div>
      </div>
    </div>

    <!-- PROPUESTA 2: Logotipo Tipográfico Funcional -->
    <div
      class="flex flex-col gap-2 p-6 bg-background rounded-md border border-border"
    >
      <span class="text-xs font-mono text-text-muted">
        Propuesta 2 (Tipográfico con Flecha oculta en X)
      </span>
      <div class="flex items-center">
        <div
          class="font-heading text-3xl font-black uppercase tracking-tighter flex items-center"
        >
          <span class="text-primary">Carico</span>
          <span class="text-primary-light relative flex items-center">
            <span>x</span>
            <!-- Mini flecha de acento integrada en el espacio de la X -->
            <span
              class="absolute -right-3 text-accent text-xl font-sans font-bold select-none"
            >
              →
            </span>
          </span>
          <span class="text-primary-light ml-3">press</span>
        </div>
      </div>
    </div>

    <!-- PROPUESTA 3: Logotipo de Monograma Lineal Integrado -->
    <div
      class="flex flex-col gap-2 p-6 bg-background rounded-md border border-border"
    >
      <span class="text-xs font-mono text-text-muted">
        Propuesta 3 (Isotipo X Asimétrica + Tipografía Integrada)
      </span>
      <div class="flex items-center gap-4">
        <div class="relative size-10 flex items-center justify-center shrink-0">
          <div
            class="absolute w-2.5 h-9 bg-primary rounded-full transform -rotate-45 translate-x-[-2px]"
          >
          </div>
          <div
            class="absolute w-2.5 h-5 bg-accent rounded-full transform -rotate-45 translate-y-[-6px] translate-x-[10px]"
          >
          </div>
          <div
            class="absolute size-2 bg-primary-light rounded-full bottom-1 right-1"
          >
          </div>
        </div>

        <div class="font-heading text-2xl uppercase tracking-tight">
          <span class="font-black text-primary">Carico</span><span
            class="font-bold text-accent"
          >
            xpress
          </span>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

---
interface Props {
  title?: string;
  description?: string;
  action?: string;
  bgClass?: string;
  containerClass?: string;
  buttonText?: string;
}

const {
  title = "¿Listo para enviar? Contáctenos",
  description = "Escríbanos para solicitar tarifas, aclarar dudas sobre su casillero o cotizar su próximo envío. Le responderemos en menos de 24 horas hábiles.",
  action = "/contacto/mensaje-enviado",
  bgClass = "",
  containerClass = "mx-auto max-w-xl px-4 sm:px-6",
  buttonText = "Enviar Mensaje",
} = Astro.props;
---

<section class={`py-section ${bgClass}`}>
  <div class={containerClass}>
    <div>
      <h2 class="font-heading text-h2 font-bold uppercase text-text">
        {title}
      </h2>
      <p class="mt-2 mb-8 text-text-muted text-pretty">
        {description}
      </p>

      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action={action}
        class="flex flex-col gap-5"
      >
        <input
          type="hidden"
          name="form-name"
          value="contact"
        />
        <p
          class="hidden"
          aria-hidden="true"
        >
          <label>
            Deje este campo vacío: <input
              name="bot-field"
              tabindex="-1"
              autocomplete="off"
            />
          </label>
        </p>

        <label class="flex flex-col gap-1.5">
          <span class="text-sm font-medium text-text">
            Nombre <span
              class="text-accent"
              aria-hidden="true"
            >
              *
            </span>
          </span>
          <input
            type="text"
            name="name"
            placeholder="Nombre y apellido"
            required
            autocomplete="name"
            class="min-h-11 rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
          />
        </label>

        <label class="flex flex-col gap-1.5">
          <span class="text-sm font-medium text-text">
            Email <span
              class="text-accent"
              aria-hidden="true"
            >
              *
            </span>
          </span>
          <input
            type="email"
            name="email"
            placeholder="correo@ejemplo.com"
            required
            autocomplete="email"
            class="min-h-11 rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
          />
        </label>

        <label class="flex flex-col gap-1.5">
          <span class="text-sm font-medium text-text">Teléfono</span>
          <input
            type="tel"
            name="phone"
            placeholder="+58 414 0000000"
            autocomplete="tel"
            inputmode="tel"
            class="min-h-11 rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
          />
        </label>

        <label class="flex flex-col gap-1.5">
          <span class="text-sm font-medium text-text">
            Mensaje <span
              class="text-accent"
              aria-hidden="true"
            >
              *
            </span>
          </span>
          <textarea
            name="message"
            rows="5"
            placeholder="Cuéntenos qué desea enviar, desde dónde y hacia qué ciudad."
            required
            class="min-h-30 rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 resize-y"
          ></textarea>
        </label>

        <button
          type="submit"
          class="mt-2 inline-flex min-h-11 cursor-pointer items-center justify-center self-start rounded-md bg-accent px-8 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >
          {buttonText}
        </button>
      </form>
    </div>
  </div>
</section>

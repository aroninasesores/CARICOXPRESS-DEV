---
// Si este código está en un archivo de componente separado (ej. ContactForm.astro),
// necesitas definir la interfaz y recibir las props así:

interface Props {
  bgClass?: string;
}

const {bgClass = ""} = Astro.props;
---

{
  /* 🟢 OPTIMIZADO: Agregamos la clase dinámica bgClass combinada con py-section */
}
<section class={`py-section ${bgClass}`}>
  <div class="mx-auto max-w-xl gap-10 px-4 sm:px-6 lg:gap-14">
    <!-- Form -->
    <div class="lg:col-span-3">
      <h2 class="font-heading text-h2 font-bold uppercase text-text">
        ¿Listo para enviar? Contáctenos
      </h2>
      <p class="mt-2 mb-8 text-text-muted">
        Escríbanos para solicitar tarifas, aclarar dudas sobre su casillero o
        cotizar su próximo envío. Le responderemos en menos de 24 horas hábiles.
      </p>

      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/contacto/success"
        class="flex flex-col gap-5"
      >
        <input
          type="hidden"
          name="form-name"
          value="contact"
        />
        <p
          class="hidden"
          aria-hidden="true"
        >
          <label>
            Leave this empty: <input
              name="bot-field"
              tabindex="-1"
              autocomplete="off"
            />
          </label>
        </p>

        <label class="flex flex-col gap-1.5">
          <span class="text-sm font-medium text-text">
            Nombre <span
              class="text-accent"
              aria-hidden="true"
            >
              *
            </span>
          </span>
          {/* 🟢 OPTIMIZADO: Cambiado min-h-[44px] por min-h-11 */}
          <input
            type="text"
            name="name"
            required
            autocomplete="name"
            class="min-h-11 rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
          />
        </label>

        <label class="flex flex-col gap-1.5">
          <span class="text-sm font-medium text-text">
            Email <span
              class="text-accent"
              aria-hidden="true"
            >
              *
            </span>
          </span>
          {/* 🟢 OPTIMIZADO: Cambiado min-h-[44px] por min-h-11 */}
          <input
            type="email"
            name="email"
            required
            autocomplete="email"
            class="min-h-11 rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
          />
        </label>

        <label class="flex flex-col gap-1.5">
          <span class="text-sm font-medium text-text">Teléfono</span>
          {/* 🟢 OPTIMIZADO: Cambiado min-h-[44px] por min-h-11 */}
          <input
            type="tel"
            name="phone"
            autocomplete="tel"
            inputmode="tel"
            class="min-h-11 rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
          />
        </label>

        <label class="flex flex-col gap-1.5">
          <span class="text-sm font-medium text-text">
            Mensaje <span
              class="text-accent"
              aria-hidden="true"
            >
              *
            </span>
          </span>
          <textarea
            name="message"
            rows="5"
            required
            class="min-h-30 rounded-md border border-border bg-background px-4 py-2.5 text-text transition-colors focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 resize-y"
          >
          </textarea>
        </label>

        {/* 🟢 OPTIMIZADO: Cambiado min-h-[44px] por min-h-11 */}
        <button
          type="submit"
          class="mt-2 inline-flex min-h-11 cursor-pointer items-center justify-center self-start rounded-md bg-accent px-8 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >
          Enviar Mensaje
        </button>
      </form>
    </div>
  </div>
</section>

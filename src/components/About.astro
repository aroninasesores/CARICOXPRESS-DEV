---
import {Image} from "astro:assets";
import type {ImageMetadata} from "astro";
import {aboutImage as localAboutImage} from "../config/images";

const PLACEHOLDER =
  "https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=900&q=80";

interface Props {
  topper?: string;
  heading?: string;
  body?: string[];
  benefits?: string[];
  ctaLabel?: string;
  ctaHref?: string;
  imageSrc?: ImageMetadata | string;
  imageAlt?: string;
  bgClass?: string;
}

const {
  topper = "Quiénes Somos",
  heading = "Un aliado logístico para sus compras y envíos a Venezuela",
  body = [
    "En CaricoXpress ayudamos a personas, familias y negocios a mover paquetes, compras online y carga comercial desde Miami hasta Venezuela con un proceso claro y atención cercana.",
    "Nuestro enfoque es simple: recibir, organizar, consolidar y despachar su carga con comunicación constante, tarifas claras y opciones adaptadas al tipo de envío.",
  ],
  benefits = [
    "Dirección física en Miami para recibir compras online",
    "Opciones aéreas y marítimas según urgencia, volumen y presupuesto",
    "Atención directa para cotizar y resolver dudas antes de enviar",
  ],
  ctaLabel = "Conozca más de nosotros",
  ctaHref = "/nosotros",
  imageSrc = localAboutImage ?? PLACEHOLDER,
  imageAlt = "Almacén logístico preparado para organizar envíos desde Miami a Venezuela",
  bgClass = "",
} = Astro.props;
---

<section class={`${bgClass} py-section`}>
  <div
    class="mx-auto grid max-w-site grid-cols-1 items-center gap-8 px-4 sm:px-6 lg:grid-cols-2 lg:gap-14"
  >
    <div class="overflow-hidden rounded-lg shadow-xl shadow-blue-900/30">
      <Image
        src={imageSrc as any}
        alt={imageAlt}
        width={700}
        height={525}
        loading="lazy"
        decoding="async"
        class="size-full object-cover"
      />
    </div>

    <div class="space-y-5">
      <span class="text-topper font-bold uppercase tracking-widest text-accent">
        {topper}
      </span>
      <h2 class="font-heading text-h2 font-bold uppercase text-text">
        {heading}
      </h2>

      {
        body.map((paragraph) => (
          <p class="text-text-muted leading-relaxed">{paragraph}</p>
        ))
      }

      <ul
        class="space-y-3 pt-2"
        role="list"
      >
        {
          benefits.map((benefit) => (
            <li class="flex items-start gap-3">
              <svg
                class="mt-0.5 size-5 shrink-0 text-accent"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"
                />
              </svg>
              <span class="text-text">{benefit}</span>
            </li>
          ))
        }
      </ul>

      <div class="pt-2">
        <a
          href={ctaHref}
          class="inline-flex min-h-11 items-center gap-2 rounded-md bg-primary px-6 py-3 text-base font-bold text-primary-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        >
          {ctaLabel}
          <svg
            class="size-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"
            />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

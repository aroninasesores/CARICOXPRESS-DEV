---
import {Image} from "astro:assets";
import type {ImageMetadata} from "astro";
import {aboutImage as localAboutImage} from "../config/images";

// Fallback Unsplash URL used until a local image is added to
// src/assets/images/about/ and registered in src/config/images.ts
const PLACEHOLDER =
  "https://images.unsplash.com/photo-1581578731548-c64695cc6952?w=900&q=80";

// 🟢 UNIFICADO: Todas las props viven en una sola interfaz limpia
interface Props {
  topper?: string;
  heading?: string;
  body?: string[];
  benefits?: string[];
  ctaLabel?: string;
  ctaHref?: string;
  imageSrc?: ImageMetadata | string;
  imageAlt?: string;
  bgClass?: string;
}

// 🟢 UNIFICADO: Una sola asignación de props con sus respectivos fallbacks
const {
  topper = "Quiénes Somos",
  heading = "Su aliado logístico con más de 10 años de trayectoria",
  body = [
    "Somos una empresa especializada en transporte internacional y gestión aduanera, comprometida con conectar de forma eficiente y segura a nuestros clientes corporativos y particulares con el mercado global.",
    "Nuestra reputación se ha consolidado gracias a la puntualidad en nuestras salidas semanales, la transparencia absoluta en los costos y un equipo de profesionales dedicados a simplificar la cadena de envíos hacia Venezuela.",
  ],
  benefits = [
    "Infraestructura propia y almacenes físicos en origen",
    "Tarifas todo incluido sin cargos sorpresa en aduana",
    "Monitoreo constante y manejo seguro de la carga",
  ],
  ctaLabel = "Conozca Más de Nosotros",
  ctaHref = "/nosotros",
  imageSrc = localAboutImage ?? PLACEHOLDER,
  imageAlt = "Equipo profesional operando en el puerto con containers de fondo",
  bgClass = "",
} = Astro.props;
---

<section class={`${bgClass} py-section`}>
  <div
    class="mx-auto grid max-w-site grid-cols-1 items-center gap-8 px-4 sm:px-6 lg:grid-cols-2 lg:gap-14"
  >
    <!-- Image -->
    <div class="overflow-hidden rounded-lg shadow-xl shadow-blue-900/30">
      <Image
        src={imageSrc as any}
        alt={imageAlt}
        width={700}
        height={525}
        loading="lazy"
        decoding="async"
        class="size-full object-cover"
      />
    </div>

    <!-- Content -->
    <div class="space-y-5">
      <span class="text-topper font-bold uppercase tracking-widest text-accent">
        {topper}
      </span>
      <h2 class="font-heading text-h2 font-bold uppercase text-text">
        {heading}
      </h2>

      {
        body.map((paragraph) => (
          <p class="text-text-muted leading-relaxed">{paragraph}</p>
        ))
      }

      {/* Benefits list */}
      <ul
        class="space-y-3 pt-2"
        role="list"
      >
        {
          benefits.map((benefit) => (
            <li class="flex items-start gap-3">
              <svg
                class="mt-0.5 size-5 shrink-0 text-accent"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M5 13l4 4L19 7"
                />
              </svg>
              <span class="text-text">{benefit}</span>
            </li>
          ))
        }
      </ul>

      <div class="pt-2">
        {
          /* 🟢 OPTIMIZADO: Cambiado min-h-[44px] por min-h-11 como recomendó Tailwind */
        }
        <a
          href={ctaHref}
          class="inline-flex min-h-11 items-center gap-2 rounded-md bg-primary px-6 py-3 text-base font-bold text-primary-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        >
          {ctaLabel}
          <svg
            class="size-4"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"
            >
            </path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

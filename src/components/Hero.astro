---
import {Image} from "astro:assets";
import type {ImageMetadata} from "astro";
import {brand} from "../config/brand";
import {client} from "../data/client";
import {heroImage as localHeroImage} from "../config/images";

// Fallback Unsplash URL used until a local image is added to
// src/assets/images/hero/ and registered in src/config/images.ts
const PLACEHOLDER =
  "https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=1200&q=80";

interface Props {
  topper?: string;
  heading?: string;
  description?: string;
  ctaLabel?: string;
  ctaHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  imageSrc?: ImageMetadata | string;
  imageAlt?: string;
}

const {
  topper = "Todo tipo de carga",
  heading = brand.tagline,
  description = brand.description,
  ctaLabel = "Solicite un presupuesto",
  ctaHref = "https://wa.me/584141018217?text=Hola,%20quisiera%20solicitar%20un%20presupuesto%20para%20un%20env%C3%ADo.%20%C2%BFMe%20podr%C3%ADan%20dar%20m%C3%A1s%20informaci%C3%B3n?",
  secondaryLabel = "Nuestros Servicios",
  secondaryHref = "/services",
  imageSrc = localHeroImage ?? PLACEHOLDER,
  imageAlt = "Professional tradesperson at work",
} = Astro.props;
---

<section class="relative overflow-hidden bg-background py-12 md:py-16">
  <div
    class="mx-auto grid max-w-site grid-cols-1 items-center gap-8 px-4 sm:px-6 lg:grid-cols-2 lg:gap-12"
  >
    <!-- Copy -->
    <div class="order-2 space-y-5 lg:order-1 lg:space-y-6">
      {
        topper && (
          <span class="inline-block rounded-full bg-accent/10 px-4 py-1.5 text-topper font-bold uppercase tracking-widest text-accent">
            {topper}
          </span>
        )
      }

      <h1
        class="font-heading text-display font-bold uppercase leading-none tracking-tight text-text"
        transition:name="hero-heading"
      >
        {heading}
      </h1>

      <p class="max-w-lg text-lead text-text-muted leading-relaxed">
        {description}
      </p>

      <!-- CTA row -->
      <div
        class="flex flex-col gap-3 pt-2 sm:flex-row sm:items-center sm:gap-4"
      >
        <a
          href={ctaHref}
          class="inline-flex min-h-[44px] gap-x-1.5 items-center justify-center rounded-md bg-accent px-6 py-3 text-base font-bold text-accent-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="1.5em"
            height="1.5em"
            viewBox="0 0 24 24"
          >
            <path
              d="M0 0h24v24H0z"
              fill="none"
            >
            </path>
            <path
              fill="currentColor"
              d="M19.05 4.91A9.82 9.82 0 0 0 12.04 2c-5.46 0-9.91 4.45-9.91 9.91c0 1.75.46 3.45 1.32 4.95L2.05 22l5.25-1.38c1.45.79 3.08 1.21 4.74 1.21c5.46 0 9.91-4.45 9.91-9.91c0-2.65-1.03-5.14-2.9-7.01m-7.01 15.24c-1.48 0-2.93-.4-4.2-1.15l-.3-.18l-3.12.82l.83-3.04l-.2-.31a8.26 8.26 0 0 1-1.26-4.38c0-4.54 3.7-8.24 8.24-8.24c2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.83c.02 4.54-3.68 8.23-8.22 8.23m4.52-6.16c-.25-.12-1.47-.72-1.69-.81c-.23-.08-.39-.12-.56.12c-.17.25-.64.81-.78.97c-.14.17-.29.19-.54.06c-.25-.12-1.05-.39-1.99-1.23c-.74-.66-1.23-1.47-1.38-1.72c-.14-.25-.02-.38.11-.51c.11-.11.25-.29.37-.43s.17-.25.25-.41c.08-.17.04-.31-.02-.43s-.56-1.34-.76-1.84c-.2-.48-.41-.42-.56-.43h-.48c-.17 0-.43.06-.66.31c-.22.25-.86.85-.86 2.07s.89 2.4 1.01 2.56c.12.17 1.75 2.67 4.23 3.74c.59.26 1.05.41 1.41.52c.59.19 1.13.16 1.56.1c.48-.07 1.47-.6 1.67-1.18c.21-.58.21-1.07.14-1.18s-.22-.16-.47-.28"
            >
            </path>
          </svg>

          {ctaLabel}
        </a>
        <a
          href={secondaryHref}
          class="inline-flex min-h-[44px] items-center justify-center rounded-md border-2 border-primary px-6 py-3 text-base font-bold text-primary transition-colors hover:bg-primary hover:text-primary-fg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        >
          {secondaryLabel}
        </a>
      </div>

      <!-- Tap-to-call -->
      <a
        href={`tel:${client.phoneForTel}`}
        class="inline-flex items-center gap-2 pt-1 text-sm font-semibold text-text-muted transition-colors hover:text-primary"
      >
        <svg
          class="size-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
          >
          </path>
        </svg>
        Llámenos {client.phoneFormatted}
      </a>
    </div>

    <!-- Hero image -->
    <div
      class="relative order-1 overflow-hidden rounded-lg shadow-xl aspect-4/3 lg:order-2"
      transition:name="hero-image"
    >
      <Image
        src={imageSrc}
        alt={imageAlt}
        width={800}
        height={600}
        loading="eager"
        decoding="async"
        class="size-full object-cover"
      />
    </div>
  </div>
</section>

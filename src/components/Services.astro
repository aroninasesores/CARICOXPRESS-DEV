---
interface ServiceItem {
  title: string;
  description: string;
  href?: string;
  iconPath: string;
}

interface Props {
  topper?: string;
  heading?: string;
  description?: string;
  services?: ServiceItem[];
}

const {
  topper = "Soluciones Logísticas",
  heading = "Elija cómo quiere traer su carga",
  description = "Concentramos la home en las tres formas más buscadas por nuestros clientes: aéreo, marítimo y casillero en Miami. Las soluciones corporativas viven con más detalle en servicios.",
  services = [
    {
      title: "Envío Aéreo Express",
      description:
        "Para paquetes urgentes, compras personales y mercancía liviana que necesita llegar rápido a Venezuela.",
      href: "/servicios",
      iconPath:
        "M16 10h4a2 2 0 010 4h-4l-4 7H9l2-7H7l-2 2H2l2-4-2-4h3l2 2h4L9 3h3l4 7z",
    },
    {
      title: "Envío Marítimo",
      description:
        "Ideal para cajas grandes, carga pesada, reposición de inventario y envíos donde conviene optimizar costos.",
      href: "/servicios",
      iconPath:
        "M2 20a2.4 2.4 0 002 1 2.4 2.4 0 002-1 2.4 2.4 0 012-1 2.4 2.4 0 012 1 2.4 2.4 0 002 1 2.4 2.4 0 002-1 2.4 2.4 0 012-1 2.4 2.4 0 012 1 2.4 2.4 0 002 1 2.4 2.4 0 002-1M4 18l-1-5h18l-2 4M5 13V7h8l4 6M7 7V3H6",
    },
    {
      title: "Casillero Internacional",
      description:
        "Reciba sus compras online en nuestra dirección de Miami y coordine el envío cuando esté listo.",
      href: "/servicios",
      iconPath:
        "M10 21v-6.5a3.5 3.5 0 00-7 0V21h18v-6a4 4 0 00-4-4H6.5M12 11V3h4l2 2-2 2h-4M6 15h1",
    },
  ],
} = Astro.props;
---

<section class="py-section">
  <div class="mx-auto max-w-site px-4 sm:px-6">
    <div class="mx-auto mb-10 max-w-3xl text-center lg:mb-14">
      <span class="text-topper font-bold uppercase tracking-widest text-accent">
        {topper}
      </span>
      <h2 class="mt-2 font-heading text-h2 font-bold uppercase text-text">
        {heading}
      </h2>
      <p class="mt-3 text-text-muted leading-relaxed text-pretty">
        {description}
      </p>
    </div>

    <ul
      class="grid grid-cols-1 gap-6 md:grid-cols-3"
      role="list"
    >
      {
        services.map((service) => (
          <li>
            <a
              href={service.href || "/servicios"}
              aria-label={`Conozca nuestros ${service.title}`}
              class="group flex h-full cursor-pointer flex-col rounded-lg border border-border bg-background p-6 shadow-sm transition-all duration-200 hover:-translate-y-1 hover:shadow-xl"
            >
              <div class="mb-5 flex size-14 items-center justify-center rounded-lg bg-primary/10 text-primary transition-colors group-hover:bg-primary group-hover:text-primary-fg">
                <svg
                  class="size-7"
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path d={service.iconPath} />
                </svg>
              </div>
              <h3 class="font-heading text-h3 font-semibold text-text">
                {service.title}
              </h3>
              <p class="mt-3 flex-1 text-sm leading-relaxed text-text-muted text-pretty">
                {service.description}
              </p>
              <span class="mt-5 inline-flex items-center gap-2 text-sm font-bold text-primary transition-colors group-hover:text-accent">
                Ver servicio
                <span class="sr-only"> sobre {service.title}</span>
                <svg
                  class="size-4 transition-transform group-hover:translate-x-1"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 8l4 4m0 0l-4 4m4-4H3"
                  />
                </svg>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>

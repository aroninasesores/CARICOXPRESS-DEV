---
import {brand} from "../config/brand";
import {client} from "../data/client";
import Logo from "./logo.astro";

const year = new Date().getFullYear();

const navCols = [
  {
    title: "Acerca de",
    links: [
      {label: "Inicio", href: "/"},
      {label: "Servicios", href: "/servicios"},
      {label: "Blog", href: "/blog"},
      {label: "Reseñas", href: "/resenas"},
      {label: "Nosotros", href: "/nosotros"},
    ],
  },
  {
    title: "Soporte",
    links: [
      {label: "Contacto", href: "/contacto"},
      {label: "Privacidad", href: "/privacy"},
      {label: "Términos", href: "/terms"},
    ],
  },
];
---

<footer
  class="bg-dark text-surface/80"
  transition:persist
>
  <div class="mx-auto max-w-site px-4 py-12 sm:px-6 lg:py-16">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="flex items-center gap-3 mb-4 brightness-0 invert">
          <Logo />
        </div>
        <p class="mt-3 max-w-xs text-sm leading-relaxed">
          {brand.tagline} puerta a puerta <br />
          {brand.tagline2}
          {brand.tagline3}
          {brand.tagline4}
        </p>

        <!-- Social links -->
        <div class="mt-5 flex items-center gap-4">
          <!-- {
            client.socials.facebook && (
              <a
                href={client.socials.facebook}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Facebook"
                class="text-surface/60 transition-colors hover:text-white"
              >
                <svg
                  class="size-5"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" />
                </svg>
              </a>
            )
          } -->
          {
            client.socials.instagram && (
              <a
                href={client.socials.instagram}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Instagram"
                class="text-surface/60 transition-colors hover:text-white"
              >
                <svg
                  class="size-5"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
                </svg>
              </a>
            )
          }
          {
            client.socials.google && (
              <a
                href={client.socials.google}
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Google Business"
                class="text-surface/60 transition-colors hover:text-white"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="icon icon-tabler icons-tabler-outline icon-tabler-map-pin"
                >
                  <>
                    <path
                      stroke="none"
                      d="M0 0h24v24H0z"
                      fill="none"
                    />
                    <path d="M9 11a3 3 0 1 0 6 0a3 3 0 0 0 -6 0" />
                    <path d="M17.657 16.657l-4.243 4.243a2 2 0 0 1 -2.827 0l-4.244 -4.243a8 8 0 1 1 11.314 0" />
                  </>
                </svg>
              </a>
            )
          }
        </div>
      </div>

      <!-- Nav columns -->
      {
        navCols.map((col) => (
          <div>
            <h3 class="text-sm font-bold uppercase tracking-wider text-white">
              {col.title}
            </h3>
            <ul class="mt-3 space-y-2">
              {col.links.map(({label, href}) => (
                <li>
                  <a
                    href={href}
                    class="text-sm transition-colors hover:text-white"
                  >
                    {label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }

      <!-- Contact info -->
      <div>
        <h3 class="text-sm font-bold uppercase tracking-wider text-white">
          Contacto
        </h3>
        <ul class="mt-3 space-y-2 text-sm">
          <li>
            <a
              href={`tel:${client.phoneForTel}`}
              class="flex flex-row gap-2 transition-colors hover:text-white"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="icon icon-tabler icons-tabler-outline icon-tabler-phone"
              >
                <path
                  stroke="none"
                  d="M0 0h24v24H0z"
                  fill="none"
                >
                </path><path
                  d="M5 4h4l2 5l-2.5 1.5a11 11 0 0 0 5 5l1.5 -2.5l5 2v4a2 2 0 0 1 -2 2a16 16 0 0 1 -15 -15a2 2 0 0 1 2 -2"
                >
                </path>
              </svg>
              {client.phoneFormatted}
            </a>
          </li>
          <li>
            <a
              href={`mailto:${client.email}`}
              class="flex flex-row gap-2 transition-colors hover:text-white"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="icon icon-tabler icons-tabler-outline icon-tabler-mail"
              >
                <path
                  stroke="none"
                  d="M0 0h24v24H0z"
                  fill="none"
                >
                </path>
                <path
                  d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10"
                >
                </path>
                <path d="M3 7l9 6l9 -6"></path>
              </svg>
              {client.email}
            </a>
          </li>
          <li>
            <a
              href={client.address.mapLink}
              target="_blank"
              rel="noopener noreferrer"
              class="flex flex-row gap-2 transition-colors hover:text-white"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="icon icon-tabler icons-tabler-outline icon-tabler-pin"
              >
                <path
                  stroke="none"
                  d="M0 0h24v24H0z"
                  fill="none"
                >
                </path><path
                  d="M15 4.5l-4 4l-4 1.5l-1.5 1.5l7 7l1.5 -1.5l1.5 -4l4 -4"
                >
                </path><path d="M9 15l-4.5 4.5"></path><path
                  d="M14.5 4l5.5 5.5"
                >
                </path>
              </svg>
              {client.address.lineOne}
              {client.address.lineTwo}<br />
              {client.address.city}, {client.address.state}
              {client.address.zip}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-10 border-t border-surface/10 pt-6 text-center text-sm">
      &copy; {year}
      {brand.name}. Todos los derechos reservados.
    </div>
    <div class="pt-4 text-center text-xs italic text-surface/60">
      Diseñado y desarrollado por:
      <a
        href="https://www.aroninasesores.com"
        target="_blank"
        rel="noopener noreferrer"
        class="text-surface/80 transition-colors hover:text-white"
      >
        Arönin Asesores
      </a>
    </div>
  </div>
</footer>

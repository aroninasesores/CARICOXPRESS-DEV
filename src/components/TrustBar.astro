---
interface TrustItem {
  label: string;
  value?: string;
  icon: "calendar" | "warehouse" | "award" | "box"; // Restringimos los nombres para evitar errores de tipeo
}

interface Props {
  items?: TrustItem[];
}

const {
  items = [
    {label: "Salidas Semanales", icon: "calendar"},
    {label: "Almacenes Propios", icon: "warehouse"},
    {label: "Años de Experiencia", value: "+10", icon: "award"},
    {label: "Cargas Entregadas", value: "+5,000", icon: "box"},
  ],
} = Astro.props;
---

<section
  class="border-y border-border bg-surface"
  aria-label="Trust signals"
>
  <div class="mx-auto max-w-site overflow-x-auto px-4 py-5 sm:px-6 sm:py-6">
    <ul
      class="flex flex-wrap items-center justify-between gap-6 sm:gap-8 lg:justify-center lg:gap-16"
      role="list"
    >
      {
        items.map(({label, value, icon}) => (
          <li class="flex shrink-0 items-center gap-2.5 text-sm sm:text-base">
            {/* CONTENEDOR DINÁMICO DE ÍCONOS DE LUCIDE / HEROICONS */}
            <svg
              class="size-5 shrink-0 text-accent"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              {icon === "calendar" && (
                <>
                  <rect
                    x="3"
                    y="4"
                    width="18"
                    height="18"
                    rx="2"
                    ry="2"
                  />
                  <line
                    x1="16"
                    y1="2"
                    x2="16"
                    y2="6"
                  />
                  <line
                    x1="8"
                    y1="2"
                    x2="8"
                    y2="6"
                  />
                  <line
                    x1="3"
                    y1="10"
                    x2="21"
                    y2="10"
                  />
                </>
              )}

              {icon === "warehouse" && (
                <>
                  <path d="M3 21V10l9-6 9 6v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                  <path d="M9 21V13h6v8" />
                </>
              )}

              {icon === "award" && (
                <>
                  <circle
                    cx="12"
                    cy="8"
                    r="7"
                  />
                  <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88" />
                </>
              )}

              {icon === "box" && (
                <>
                  <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" />
                  <polyline points="3.27 6.96 12 12.01 20.73 6.96" />
                  <line
                    x1="12"
                    y1="22.08"
                    x2="12"
                    y2="12"
                  />
                </>
              )}
            </svg>

            <span class="font-heading font-semibold text-text">
              {value && <span class="text-primary">{value} </span>}
              {label}
            </span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
